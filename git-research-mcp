// Minimum delay between Google requests to avoid rate-limiting (ms).
const GOOGLE_MIN_DELAY_MS = parseInt(
  process.env.GOOGLE_MIN_DELAY_MS || "3000",
  10,
);
// Extra delay added per retry when results come back empty or rate-limited.
const GOOGLE_EMPTY_RETRY_DELAY_MS = 10000;
// Max attempts specifically for empty-result / rate-limit retries.
const GOOGLE_EMPTY_RETRY_MAX = 4;
// Long backoff for 429 specifically (starts at 30s, doubles each attempt).
const GOOGLE_429_BASE_DELAY_MS = 30000;
const GOOGLE_RESULTS_PER_PAGE = 10;
const GOOGLE_DEFAULT_PAGE_COUNT = parseInt(
  process.env.GOOGLE_DEFAULT_PAGE_COUNT || "10",
  10,
);
const GOOGLE_CAPTCHA_POLL_DELAY_SECONDS = 1;
const GOOGLE_CAPTCHA_POLL_ATTEMPTS = parseInt(
  process.env.GOOGLE_CAPTCHA_POLL_ATTEMPTS || "300",
  10,
);

let _lastGoogleRequestMs = 0;

/**
 * Enforce a minimum gap between Google requests so we don't burst.
 */
async function googleRateLimit() {
  const now = Date.now();
  const elapsed = now - _lastGoogleRequestMs;
  if (elapsed < GOOGLE_MIN_DELAY_MS) {
    await sleep(GOOGLE_MIN_DELAY_MS - elapsed);
  }
  _lastGoogleRequestMs = Date.now();
}

