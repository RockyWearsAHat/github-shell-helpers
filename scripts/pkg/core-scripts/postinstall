#!/usr/bin/env bash
set -euo pipefail

log() { echo "[helpers-core] $1"; }

console_user="$(/usr/bin/stat -f%Su /dev/console 2>/dev/null || true)"
if [ -z "$console_user" ] || [ "$console_user" = "root" ] || [ "$console_user" = "loginwindow" ]; then
  exit 0
fi

user_home="$(/usr/bin/dscl . -read "/Users/$console_user" NFSHomeDirectory 2>/dev/null | /usr/bin/awk '{print $2}')"
if [ -z "$user_home" ]; then
  user_home="/Users/$console_user"
fi

user_shell="$(/usr/bin/dscl . -read "/Users/$console_user" UserShell 2>/dev/null | /usr/bin/awk '{print $2}')"
if [ -z "$user_shell" ]; then
  user_shell="${SHELL:-/bin/bash}"
fi

shell_env_dir="$user_home/.config/helpers"
shell_env_snippet="$shell_env_dir/paths-system.sh"
shell_env_source='[ -f "$HOME/.config/helpers/paths-system.sh" ] && . "$HOME/.config/helpers/paths-system.sh"'

add_line_if_missing() {
  local file="$1" line="$2"
  if [ ! -f "$file" ]; then
    /usr/bin/sudo -H -u "$console_user" -- touch "$file"
  fi
  if ! grep -qxF "$line" "$file" 2>/dev/null; then
    printf '%s\n' "$line" >>"$file"
    chown "$console_user" "$file" 2>/dev/null || true
    log "Added to $file: $line"
  fi
}

write_shell_env_snippet() {
  mkdir -p "$shell_env_dir"
  printf '%s\n' \
    '# Added by the github-shell-helpers pkg installer.' \
    'case ":${PATH:-}:" in' \
    '  *":/usr/local/bin:"*) ;;' \
    '  *) export PATH="/usr/local/bin${PATH:+:$PATH}" ;;' \
    'esac' \
    'case ":${MANPATH:-}:" in' \
    '  *":/usr/local/share/man:"*) ;;' \
    '  *) export MANPATH="/usr/local/share/man${MANPATH:+:$MANPATH}" ;;' \
    'esac' \
    >"$shell_env_snippet"
  chown "$console_user" "$shell_env_snippet"
}

default_profile_path() {
  case "${user_shell##*/}" in
    zsh)
      printf '%s\n' "$user_home/.zshrc"
      ;;
    bash)
      if [ "$(uname -s)" = "Darwin" ]; then
        printf '%s\n' "$user_home/.bash_profile"
      else
        printf '%s\n' "$user_home/.bashrc"
      fi
      ;;
    *)
      printf '%s\n' "$user_home/.profile"
      ;;
  esac
}

list_profile_targets() {
  local found=false
  local candidate
  for candidate in \
    "$user_home/.zshrc" \
    "$user_home/.zprofile" \
    "$user_home/.bash_profile" \
    "$user_home/.bashrc" \
    "$user_home/.profile"
  do
    if [ -f "$candidate" ]; then
      printf '%s\n' "$candidate"
      found=true
    fi
  done

  if [ "$found" = false ]; then
    default_profile_path
  fi
}

configure_shell_profiles() {
  local profile
  write_shell_env_snippet
  while IFS= read -r profile; do
    [ -n "$profile" ] || continue
    add_line_if_missing "$profile" "$shell_env_source"
  done < <(list_profile_targets)
}

configure_shell_profiles

# Download the prebuilt native binary for this host (Node-free) and symlink the
# CLIs. Runs as root → writes /usr/local/bin. Registration with an agent is left
# to the user's `helpers install` so it lands in their config, not root's.
if [ -f /usr/local/bin/scripts/fetch-prebuilt.sh ]; then
  pkg_version="$(cat /usr/local/bin/VERSION 2>/dev/null || echo '')"
  if /bin/bash /usr/local/bin/scripts/fetch-prebuilt.sh /usr/local/bin "$pkg_version"; then
    log "Installed helpers-native. Run 'helpers install' to register with your AI agent."
  else
    log "Could not download helpers-native; finish with: bash /usr/local/bin/scripts/fetch-prebuilt.sh /usr/local/bin --register"
  fi
fi

log "Helpers installed."
exit 0
