#!/bin/zsh

# install-git-shell-helpers
#
# One-shot (and re-runnable) installer for the custom git subcommands:
#   - git-upload
#   - git-get
#   - git-initialize
#   - git-fucked-the-push
#   - git-copilot-devops-audit
#
# Responsibilities:
#   - Ensure ~/bin and ~/man/man1 exist
#   - Install/update the git-* scripts into ~/bin (chmod +x)
#   - Install/update their man pages into ~/man/man1
#   - Ensure PATH and MANPATH in ~/.zshrc include those locations (no dups)
#
# After running, you should be able to use:
#   - git upload
#   - git get
#   - git initialize
#   - git copilot-devops-audit
# and see docs via:
#   - git help upload
#   - git help get
#   - git help initialize

set -euo pipefail

BIN_DIR="${HOME}/bin"
MAN_DIR="${HOME}/man/man1"
ZSHRC="${HOME}/.zshrc"
COMMUNITY_SETTINGS_DIR="${HOME}/.copilot"
COMMUNITY_SETTINGS_FILE="${COMMUNITY_SETTINGS_DIR}/devops-audit-community-settings.json"
DEFAULT_COMMUNITY_REPO="RockyWearsAHat/github-shell-helpers"
DEFAULT_COMMUNITY_BRANCH="main"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

ensure_dir() {
  local dir="$1"
  if [ ! -d "$dir" ]; then
    mkdir -p "$dir"
  fi
}

ensure_line_in_file() {
  local file="$1"
  local line="$2"

  if [ ! -f "$file" ]; then
    touch "$file"
  fi

  # Add line only if it doesn't already exist (exact match)
  if ! grep -qxF "$line" "$file" 2>/dev/null; then
    printf '%s\n' "$line" >>"$file"
  fi
}

install_script() {
  local name="$1"
  local src="${SCRIPT_DIR}/${name}"
  local dest="${BIN_DIR}/${name}"

  if [ ! -f "$src" ]; then
    echo "[install-git-shell-helpers] WARNING: source script not found: $src" >&2
    return
  fi

  if [ "$src" != "$dest" ]; then
    cp "$src" "$dest"
  fi
  chmod +x "$dest"
  echo "[install-git-shell-helpers] Installed script: $dest"
}

install_support_script() {
  local src_rel="$1"
  local dest_name="$2"
  local src="${SCRIPT_DIR}/${src_rel}"
  local dest="${BIN_DIR}/${dest_name}"

  if [ ! -f "$src" ]; then
    echo "[install-git-shell-helpers] WARNING: support script not found: $src" >&2
    return
  fi

  if [ "$src" != "$dest" ]; then
    cp "$src" "$dest"
  fi
  chmod +x "$dest"
  echo "[install-git-shell-helpers] Installed support script: $dest"
}

write_community_settings() {
  local mode="$1"
  local local_clone=""

  if [ -f "$SCRIPT_DIR/community-cache/manifest.json" ]; then
    local_clone="$SCRIPT_DIR"
  fi

  ensure_dir "$COMMUNITY_SETTINGS_DIR"
  cat >"$COMMUNITY_SETTINGS_FILE" <<EOF
{
  "schemaVersion": 1,
  "mode": "${mode}",
  "communityRepo": "${DEFAULT_COMMUNITY_REPO}",
  "baseBranch": "${DEFAULT_COMMUNITY_BRANCH}",
  "branchPrefix": "automation/community-cache-submission"$( [ -n "$local_clone" ] && printf ',\n  "localClone": "%s"' "$local_clone" )
}
EOF
  echo "[install-git-shell-helpers] Wrote community cache settings: $COMMUNITY_SETTINGS_FILE"
}

configure_community_cache() {
  local reply=""
  local mode="pull-only"

  printf '[install-git-shell-helpers] Enable privacy-safe community cache uploads after successful audits? [y/N]: '
  read -r reply || reply=""
  if [[ "$reply" == "y" || "$reply" == "Y" ]]; then
    mode="pull-and-auto-submit"
  fi

  write_community_settings "$mode"

  if "${BIN_DIR}/git-copilot-devops-audit-community-pull" >/dev/null 2>&1; then
    echo "[install-git-shell-helpers] Pulled the latest shared DevOps audit community cache."
  else
    echo "[install-git-shell-helpers] WARNING: failed to pull the shared DevOps audit community cache." >&2
  fi
}

find_vscode_cli() {
  local candidate

  if command -v code >/dev/null 2>&1; then
    command -v code
    return 0
  fi

  for candidate in \
    "$HOME/Applications/Visual Studio Code.app/Contents/Resources/app/bin/code" \
    "/Applications/Visual Studio Code.app/Contents/Resources/app/bin/code" \
    "$HOME/Applications/Visual Studio Code - Insiders.app/Contents/Resources/app/bin/code" \
    "/Applications/Visual Studio Code - Insiders.app/Contents/Resources/app/bin/code"
  do
    if [ -x "$candidate" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  return 1
}

maybe_install_vscode_extensions() {
  local code_cli="$1"
  local reply=""

  printf '[install-git-shell-helpers] Install or update VS Code GitHub Copilot extensions now? [Y/n]: '
  read -r reply || reply=""

  if [[ -n "$reply" && "$reply" != "y" && "$reply" != "Y" ]]; then
    echo "[install-git-shell-helpers] Skipped VS Code extension install. Install GitHub.copilot and GitHub.copilot-chat later if needed."
    return
  fi

  if "$code_cli" --install-extension GitHub.copilot --force >/dev/null 2>&1; then
    echo "[install-git-shell-helpers] Installed or updated VS Code extension: GitHub.copilot"
  else
    echo "[install-git-shell-helpers] Failed to install VS Code extension: GitHub.copilot" >&2
  fi

  if "$code_cli" --install-extension GitHub.copilot-chat --force >/dev/null 2>&1; then
    echo "[install-git-shell-helpers] Installed or updated VS Code extension: GitHub.copilot-chat"
  else
    echo "[install-git-shell-helpers] Failed to install VS Code extension: GitHub.copilot-chat" >&2
  fi

  # Install the git-shell-helpers settings extension
  maybe_install_settings_extension "$code_cli"
}

maybe_install_settings_extension() {
  local code_cli="$1"
  local ext_dir="$SCRIPT_DIR/vscode-extension"

  if [[ ! -d "$ext_dir" ]]; then
    echo "[install-git-shell-helpers] VS Code settings extension directory not found, skipping."
    return
  fi

  local vsix_file
  vsix_file=$(find "$ext_dir" -maxdepth 1 -name '*.vsix' -print -quit 2>/dev/null)

  # Build if no .vsix exists or if source is newer
  if [[ -z "$vsix_file" ]] || [[ "$ext_dir/package.json" -nt "$vsix_file" ]] || [[ "$ext_dir/extension.js" -nt "$vsix_file" ]]; then
    if command -v npx >/dev/null 2>&1; then
      echo "[install-git-shell-helpers] Building git-shell-helpers VS Code extension..."
      if (cd "$ext_dir" && npx @vscode/vsce package --no-dependencies --allow-missing-repository) >/dev/null 2>&1; then
        vsix_file=$(find "$ext_dir" -maxdepth 1 -name '*.vsix' -print -quit 2>/dev/null)
      else
        echo "[install-git-shell-helpers] WARNING: Failed to build VS Code settings extension. Skipping." >&2
        return
      fi
    else
      echo "[install-git-shell-helpers] npx not found, cannot build VS Code settings extension. Skipping."
      return
    fi
  fi

  if [[ -n "$vsix_file" ]]; then
    if "$code_cli" --install-extension "$vsix_file" --force >/dev/null 2>&1; then
      echo "[install-git-shell-helpers] Installed VS Code extension: git-shell-helpers (community cache settings in VS Code Settings UI)"
    else
      echo "[install-git-shell-helpers] WARNING: Failed to install git-shell-helpers VS Code extension." >&2
    fi
  fi
}

install_man_git_upload() {
  local dest="${MAN_DIR}/git-upload.1"
  cat >"$dest" <<'EOF'
.TH GIT-UPLOAD 1 "January 2026" "git-upload" "Git Manual"
.SH NAME
git-upload \- stage, commit, and push changes with optional AI commit message
.SH SYNOPSIS
.B git upload
.RI [ -ai | --aiDiffCommitMsg
.IR [ai-context] ]
.RI [ commit-message ]
.SH DESCRIPTION
.B git upload
is a convenience wrapper around
.BR git-add (1),
.BR git-commit (1),
and
.BR git-push (1)
that stages all changes in the current repository, creates a commit, and pushes
it to the
.B main
branch.
.PP
When invoked with
.BR -ai
or
.BR --aiDiffCommitMsg ,
.B git upload
uses GitHub Copilot CLI (or an overridden AI command) to generate a commit
message based on the current repository state (subject line plus optional body).
.PP
When present, repo-authored guidance is added to the AI prompt before commit
generation. This includes files such as
.IR .github/COMMIT_GUIDELINES.md ,
.IR .github/UPLOAD_GUIDELINES.md ,
.IR .github/copilot-instructions.md ,
.IR AGENTS.md ,
.IR CLAUDE.md ,
.IR CONTRIBUTING.md ,
and
.IR README.md .
.PP
If
.B VERSION
is staged with a new value and
.IR release-notes/v<version>.md
is missing,
.B git upload
will block the upload. In AI mode, it first attempts to generate and stage the
missing release notes file before creating the commit message.
.SH OPTIONS
.TP
.BR -ai ,
.BR --aiDiffCommitMsg
Enable AI-based commit message generation. If installed and configured,
GitHub Copilot CLI is used to create an informative commit message (subject line plus optional body).
.TP
.I ai-context
Optional free-form text immediately following
.BR -ai
or
.BR --aiDiffCommitMsg .
This text is appended as additional context to the default AI prompt.
.TP
.I commit-message
Optional manual commit message. When AI is enabled, this is used as a
fallback if AI is unavailable or fails. When AI is not enabled, this becomes
the commit message. If omitted, a default commit message is used.
.SH AI INTEGRATION
By default
.B git upload
invokes the
.BR copilot (1)
CLI with a carefully crafted prompt instructing it to output a single git
commit message (subject line plus optional body).
.PP
The prompt also includes bounded excerpts from repo-authored guidance files so
the model can follow project-specific commit and upload workflow rules without
reading the repository itself.
.PP
When AI mode is enabled and a version bump is staged without matching release
notes, the same AI command is also used to generate a concise
.IR release-notes/v<version>.md
file before the commit is created.
.PP
If the environment variable
.B GIT_UPLOAD_AI_CMD
is set, its value is used instead of the default Copilot command. The AI
command is executed with the environment variable
.B GIT_UPLOAD_AI_PROMPT
containing the final prompt text.
.PP
If AI is requested (using
.BR -ai )
and the AI command is not available or fails, and no manual commit message
was provided, the command aborts without creating a commit.
.SH EXAMPLES
.TP
Generate a commit message using AI and push:
.EX
git upload -ai
.EE
.TP
Use AI with extra context and a manual fallback message:
.EX
git upload -ai "focus on UX changes" "Fallback commit message"
.EE
.TP
Normal usage without AI:
.EX
git upload "Fix typo in README"
.EE
.SH SEE ALSO
.BR git-commit (1),
.BR git-push (1),
.BR copilot (1)
EOF
  echo "[install-git-shell-helpers] Installed man page: $dest"
}

