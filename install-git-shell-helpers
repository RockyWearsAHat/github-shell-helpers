# ---------------------------------------------------------------------------
# MCP tools installation
# ---------------------------------------------------------------------------

VSCODE_MCP_JSON="$HOME/Library/Application Support/Code/User/mcp.json"

install_mcp_aioserver_vision() {
  local dest_dir="${BIN_DIR}/aioserver-vision-tool"
  local src_dir="${SCRIPT_DIR}/aioserver-vision-tool"

  if [ ! -d "$src_dir" ]; then
    echo "[install-git-shell-helpers] WARNING: aioserver-vision-tool source not found: $src_dir" >&2
    return 1
  fi

  ensure_dir "$dest_dir"
  for f in mcp-server.js extension.js package.json README.md LICENSE.txt; do
    if [ -f "$src_dir/$f" ]; then
      cp "$src_dir/$f" "$dest_dir/$f"
    fi
  done
  echo "[install-git-shell-helpers] Installed MCP tool: aioserver-vision -> $dest_dir"
}

maybe_install_aioserver_vision_extension() {
  local code_cli="$1"
  local ext_dir="${SCRIPT_DIR}/aioserver-vision-tool"

  if [ ! -d "$ext_dir" ] || [ ! -f "$ext_dir/package.json" ]; then
    return
  fi

  local vsix_file
  vsix_file=$(find "$ext_dir" -maxdepth 1 -name '*.vsix' -print -quit 2>/dev/null)

  if [[ -z "$vsix_file" ]] || [[ "$ext_dir/package.json" -nt "$vsix_file" ]] || [[ "$ext_dir/extension.js" -nt "$vsix_file" ]]; then
    if command -v npx >/dev/null 2>&1; then
      echo "[install-git-shell-helpers] Building aioserver-vision VS Code extension..."
      if (cd "$ext_dir" && npx @vscode/vsce package --no-dependencies --allow-missing-repository) >/dev/null 2>&1; then
        vsix_file=$(find "$ext_dir" -maxdepth 1 -name '*.vsix' -print -quit 2>/dev/null)
      else
        echo "[install-git-shell-helpers] WARNING: Failed to build aioserver-vision extension. Skipping." >&2
        return
      fi
    else
      echo "[install-git-shell-helpers] npx not found, cannot build aioserver-vision extension. Skipping."
      return
    fi
  fi

  if [[ -n "$vsix_file" ]] && [[ -n "$code_cli" ]]; then
    if "$code_cli" --install-extension "$vsix_file" --force >/dev/null 2>&1; then
      echo "[install-git-shell-helpers] Installed VS Code extension: aioserver-vision-tool"
    else
      echo "[install-git-shell-helpers] WARNING: Failed to install aioserver-vision VS Code extension." >&2
    fi
  fi
}

upsert_mcp_server() {
  local name="$1"
  local block="$2"
  local mcp_file="$VSCODE_MCP_JSON"

  ensure_dir "$(dirname "$mcp_file")"

  python3 - "$mcp_file" "$name" "$block" <<'PYEOF'
import json, sys

mcp_path, srv_name, srv_block = sys.argv[1], sys.argv[2], sys.argv[3]
try:
    with open(mcp_path, "r", encoding="utf-8") as f:
        data = json.load(f)
except (json.JSONDecodeError, FileNotFoundError):
    data = {}

if "servers" not in data or not isinstance(data["servers"], dict):
    data["servers"] = {}
if "inputs" in data and not isinstance(data["inputs"], list):
    data["inputs"] = []

data["servers"][srv_name] = json.loads(srv_block)

with open(mcp_path, "w", encoding="utf-8") as f:
    json.dump(data, f, indent=2)
    f.write("\n")
PYEOF
}

configure_mcp_tools() {
  local code_cli="${1:-}"
  local install_research=true
  local install_vision=true

  echo ""
  echo "[install-git-shell-helpers] MCP Tools (global via Git Shell Helpers extension)"
  echo "  Bundled tool modules:"
  echo "    1) git-research-mcp  — web search & knowledge cache for Copilot agents"
  echo "    2) aioserver-vision  — screenshot analysis with vision models"
  echo ""
  printf '[install-git-shell-helpers] Install MCP tools into VS Code? [Y/n/pick]: '
  read -r mcp_reply || mcp_reply=""

  if [[ "$mcp_reply" == "n" || "$mcp_reply" == "N" ]]; then
    echo "[install-git-shell-helpers] Skipped MCP tool installation."
    return
  fi

  if [[ "$mcp_reply" == "pick" || "$mcp_reply" == "p" ]]; then
    printf '  Include research tools (web search, knowledge cache)? [Y/n]: '
    read -r r1 || r1=""
    if [[ "$r1" == "n" || "$r1" == "N" ]]; then
      install_research=false
    fi

    printf '  Include vision tools (screenshot analysis)? [Y/n]: '
    read -r r2 || r2=""
    if [[ "$r2" == "n" || "$r2" == "N" ]]; then
      install_vision=false
    fi
  fi

  # Copy the combined server entry point
  local mcp_src="${SCRIPT_DIR}/git-shell-helpers-mcp"
  local mcp_dest="${BIN_DIR}/git-shell-helpers-mcp"
  if [ -f "$mcp_src" ] && [ "$mcp_src" != "$mcp_dest" ]; then
    cp "$mcp_src" "$mcp_dest"
  fi

  # Copy vision tool files if selected
  if [ "$install_vision" = true ]; then
    install_mcp_aioserver_vision
    if [[ -n "$code_cli" ]]; then
      maybe_install_aioserver_vision_extension "$code_cli"
    fi
  fi

  local server_json='{
    "type": "stdio",
    "command": "node",
    "args": ["'"${BIN_DIR}/git-shell-helpers-mcp"'"]
  }'
  upsert_mcp_server "gsh" "$server_json"

  echo "[install-git-shell-helpers] Installed MCP server runtime: ${BIN_DIR}/git-shell-helpers-mcp"
  if [ "$install_research" = true ]; then
    echo "  ✓ research tools (web search, knowledge cache, fetch pages)"
  else
    echo "  - research tools left available for later install"
  fi
  if [ "$install_vision" = true ]; then
    echo "  ✓ vision tools (screenshot analysis)"
  else
    echo "  - vision tools not installed"
  fi
  if [[ -n "$code_cli" ]]; then
    echo "[install-git-shell-helpers] Global MCP config written to: $VSCODE_MCP_JSON"
    echo "[install-git-shell-helpers] VS Code should discover git-shell-helpers from the global mcp.json entry above."
    echo "[install-git-shell-helpers] Reload VS Code to refresh MCP server discovery."
  fi
}

main() {
  echo "[install-git-shell-helpers] Installing git shell helpers..."

  ensure_dir "$BIN_DIR"
  ensure_dir "$MAN_DIR"

  install_script "git-upload"
  install_script "git-get"
  install_script "git-initialize"
  install_script "git-fucked-the-push"
  install_script "git-copilot-devops-audit"
  install_script "git-research-mcp"
  install_script "git-shell-helpers-mcp"
  install_support_script "scripts/community-cache-submit.sh" "git-copilot-devops-audit-community-submit"
  install_support_script "scripts/community-cache-pull.sh" "git-copilot-devops-audit-community-pull"
  install_support_script "scripts/community-research-submit.sh" "git-copilot-devops-audit-community-research-submit"

  # Write default git-research-mcp config if it doesn't exist
  local research_config_dir="${HOME}/.config/git-research-mcp"
  local research_env_file="${research_config_dir}/.env"
  if [ ! -f "$research_env_file" ]; then
    ensure_dir "$research_config_dir"
    cat >"$research_env_file" <<'RENV'
# SearXNG — local meta-search instance (Docker container on port 8888).
# Start with: docker run -d --name searxng -p 8888:8080 searxng/searxng:latest
SEARXNG_URL=http://localhost:8888
RENV
    echo "[install-git-shell-helpers] Wrote default config: $research_env_file"
  fi

  configure_community_cache

  install_man_git_upload
  install_man_git_get
  install_man_git_initialize
  install_man_git_fucked_the_push
  install_man_git_copilot_devops_audit
  install_man_git_research_mcp

  # Ensure PATH and MANPATH are wired in ~/.zshrc (idempotent)
  ensure_line_in_file "$ZSHRC" 'export PATH="$HOME/bin:$PATH"'
  ensure_line_in_file "$ZSHRC" 'export MANPATH="$HOME/man:$MANPATH"'

  # Optional: install private audit agents and /copilot-devops-audit prompt globally
  # -----------------------------------------------------------------------------
  # HIGHLY RECOMMENDED: Install/Update GitHub Copilot CLI
  # Enables AI commit messages (git upload -ai) and improves Copilot integration
  # -----------------------------------------------------------------------------
  echo ""
  if command -v gh >/dev/null 2>&1; then
    if gh extension list 2>/dev/null | grep -q 'gh-copilot'; then
      printf '[install-git-shell-helpers] (HIGHLY RECOMMENDED) GitHub Copilot CLI is installed. Update it now? [Y/n]: '
      read -r copilot_reply || copilot_reply=""
      if [[ -z "$copilot_reply" || "$copilot_reply" == "y" || "$copilot_reply" == "Y" ]]; then
        gh extension upgrade gh-copilot && \
          echo "[install-git-shell-helpers] GitHub Copilot CLI updated." || \
          echo "[install-git-shell-helpers] Update failed — try: gh extension upgrade gh-copilot"
      fi
    else
      printf '[install-git-shell-helpers] (HIGHLY RECOMMENDED) Install GitHub Copilot CLI? Enables AI commit messages and better Copilot integration. [Y/n]: '
      read -r copilot_reply || copilot_reply=""
      if [[ -z "$copilot_reply" || "$copilot_reply" == "y" || "$copilot_reply" == "Y" ]]; then
        gh extension install github/gh-copilot && \
          echo "[install-git-shell-helpers] GitHub Copilot CLI installed. Try: gh copilot suggest" || \
          echo "[install-git-shell-helpers] Install failed — try manually: gh extension install github/gh-copilot"
      else
        echo "[install-git-shell-helpers] Skipped. Install later with: gh extension install github/gh-copilot"
      fi
    fi
  else
    echo "[install-git-shell-helpers] (HIGHLY RECOMMENDED) GitHub CLI (gh) not found."
    echo "  Install it to enable AI commit messages and better Copilot integration:"
    if command -v brew >/dev/null 2>&1; then
      echo "  brew install gh && gh extension install github/gh-copilot"
    else
      echo "  https://cli.github.com  →  then: gh extension install github/gh-copilot"
    fi
  fi

  # Optional: install DevOpsAudit into standard user-level Copilot locations.
  VSCODE_USER_DIR="$HOME/Library/Application Support/Code/User"
  local code_cli=""
  local should_offer_vscode_setup=false

  if code_cli="$(find_vscode_cli)"; then
    should_offer_vscode_setup=true
    mkdir -p "$VSCODE_USER_DIR"

    echo ""
    maybe_install_vscode_extensions "$code_cli"
  elif [ -d "$VSCODE_USER_DIR" ]; then
    should_offer_vscode_setup=true
    echo ""
    echo "[install-git-shell-helpers] VS Code user profile found, but no usable 'code' CLI was detected."
    echo "[install-git-shell-helpers] Install the GitHub Copilot and GitHub Copilot Chat extensions manually if you want the audit surfaces to be usable in VS Code."
  fi

  if [ "$should_offer_vscode_setup" = true ]; then
    echo ""
    printf '[install-git-shell-helpers] Install private Copilot audit agents, natural-language router, and /copilot-devops-audit globally in VS Code? [Y/n]: '
    read -r vscode_reply || vscode_reply=""
    if [[ -z "$vscode_reply" || "$vscode_reply" == "y" || "$vscode_reply" == "Y" ]]; then
      "${BIN_DIR}/git-copilot-devops-audit" --update-agent --force >/dev/null 2>&1 || true
      echo "[install-git-shell-helpers] Installed DevOpsAudit agents, router, prompt, and skills into ~/.copilot."
      echo "[install-git-shell-helpers] Reload VS Code window (Cmd+Shift+P → 'Developer: Reload Window') to activate."
    else
      echo "[install-git-shell-helpers] Skipped VS Code global install. Run 'git copilot-devops-audit' in any repo to install later."
    fi

    # MCP tools — always offer when VS Code is available
    configure_mcp_tools "$code_cli"
  fi

  echo ""
  echo "[install-git-shell-helpers] Done. Open a new terminal or run:"
  echo "  source $ZSHRC"
  echo "Then you can use: git upload, git get, git initialize, git fucked-the-push,"
  echo "  git copilot-devops-audit, and view docs via git help <command>."
}

main "$@"
