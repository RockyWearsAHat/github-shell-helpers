#!/usr/bin/env node

// git-shell-helpers-mcp
//
// Combined MCP server that exposes all git-shell-helpers tools under one
// server entry. Delegates to the individual modules (git-research-mcp and
// vision-tool) which remain separate files for maintainability.
//
// Usage (standalone):
//   node git-shell-helpers-mcp
//
// MCP server name: "gsh"
// Configurable via environment variables:
//   GIT_SHELL_HELPERS_MCP_DISABLE_RESEARCH=1  — skip research tools
//   GIT_SHELL_HELPERS_MCP_DISABLE_VISION=1    — skip vision tools

const path = require("path");
const readline = require("readline");

const MCP_VERSION = "2024-11-05";
const SERVER_VERSION = "1.1.0";

function send(message) {
  process.stdout.write(`${JSON.stringify(message)}\n`);
}

function sendError(id, code, message) {
  send({
    jsonrpc: "2.0",
    id,
    error: { code, message },
  });
}

// ---------------------------------------------------------------------------
// Load sub-modules
// ---------------------------------------------------------------------------

const modules = [];

if (!process.env.GIT_SHELL_HELPERS_MCP_DISABLE_RESEARCH) {
  try {
    const research = require(path.join(__dirname, "git-research-mcp"));
    modules.push(research);
  } catch (err) {
    process.stderr.write(
      `[git-shell-helpers-mcp] WARNING: could not load git-research-mcp: ${err.message}\n`,
    );
  }
}

if (!process.env.GIT_SHELL_HELPERS_MCP_DISABLE_VISION) {
  try {
    const vision = require(
      path.join(__dirname, "vision-tool", "mcp-server.js"),
    );
    modules.push(vision);
  } catch (err) {
    process.stderr.write(
      `[git-shell-helpers-mcp] WARNING: could not load vision-tool: ${err.message}\n`,
    );
  }
}

// Merge tool lists from all loaded modules.
const ALL_TOOLS = modules.flatMap((m) => m.tools || []);

// ---------------------------------------------------------------------------
// Built-in tools (not delegated to sub-modules)
// ---------------------------------------------------------------------------

const { execFile, spawn } = require("child_process");
const fs = require("fs");

const CHECKPOINT_TOOL = {
  name: "checkpoint",
  description:
    "Create a local git commit with an AI-generated message. Stages changes, generates a commit message from the diff, commits, and optionally pushes. Pass context for extra AI hints. Optionally override with a manual message.",
  inputSchema: {
    type: "object",
    properties: {
      context: {
        type: "string",
        description:
          "Optional extra context to include in the AI prompt (e.g. 'fixes the login bug introduced in last PR'). Ignored when message is provided.",
      },
      message: {
        type: "string",
        description:
          "Optional manual override for the commit message. If omitted, the message is AI-generated from the staged diff.",
      },
      all: {
        type: "boolean",
        description:
          "Stage all changes including untracked files (git add -A) before committing. Default: true.",
      },
      push: {
        type: "boolean",
        description: "Push to remote after committing. Default: false.",
      },
      force: {
        type: "boolean",
        description:
          "Override a mid-session disable. Only use this when the user explicitly asked for a checkpoint and the previous call returned [no-op]. Never set force on automatic checkpoints.",
      },
    },
    required: [],
  },
};

ALL_TOOLS.push(CHECKPOINT_TOOL);

function execGit(args, cwd) {
  return new Promise((resolve, reject) => {
    execFile("git", args, { cwd, timeout: 30000 }, (err, stdout, stderr) => {
      if (err) {
        reject(new Error((stderr || err.message || "").trim()));
      } else {
        resolve((stdout || "").trim());
      }
    });
  });
}

async function generateAiCommitMessage(cwd, extraContext) {
  function gitOut(gitArgs) {
    return new Promise((resolve) => {
      execFile("git", gitArgs, { cwd, timeout: 15000 }, (err, stdout) => {
        resolve(err ? "" : (stdout || "").trim());
      });
    });
  }

  const changedFiles = await gitOut(["diff", "--cached", "--name-only"]);
  const statSummary = await gitOut(["diff", "--cached", "--stat"]);
  let actualDiff = await gitOut(["diff", "--cached", "--unified=3"]);
  const diffLines = actualDiff.split("\n").length;
  if (diffLines > 2000) {
    actualDiff =
      actualDiff.split("\n").slice(0, 2000).join("\n") +
      `\n(truncated — showing first 2000 of ${diffLines} lines)`;
  }

  const recentHistory = await gitOut([
    "log",
    "--oneline",
    "-10",
    "--no-decorate",
  ]);
  const detailedRecent = await gitOut([
    "log",
    "-3",
    "--pretty=format:--- %h (%ar) ---%n%s%n%n%b",
  ]);

  // Load repo guidance
  let repoGuidance = "";
  for (const gf of [
    ".github/COMMIT_GUIDELINES.md",
    ".github/commit_guidelines.md",
    ".github/COMMIT_MESSAGE.md",
    ".github/commit_message.md",
    ".github/copilot-instructions.md",
    "AGENTS.md",
    "CLAUDE.md",
    "CONTRIBUTING.md",
  ]) {
    try {
      const raw = fs.readFileSync(path.join(cwd, gf), "utf8");
      const snippet = raw.split("\n").slice(0, 120).join("\n").trim();
      if (snippet) repoGuidance += `\n--- ${gf} ---\n${snippet}\n`;
    } catch {
      /* not present */
    }
  }

  const prompt = `Write a commit message for the staged changes below.

This is a CHECKPOINT commit — the developer is marking a meaningful moment:
something works now that did not before, a logical unit of work is complete,
or they are about to switch context. Frame the message accordingly.

CONTEXT MATTERS MOST:
Read the recent commit history. Each commit is part of an ongoing thread.
Frame yours as the next step in that story.

SUBJECT LINE:
One line, <= 72 chars. Say what the commit DOES or FIXES, not what
files it touches.

BODY:
Describe the situation, what you did, and why. Someone reading git blame
should understand the reasoning without opening the diff.

Do NOT use section headers like 'What changed:', 'Why this matters:', etc.
For a tiny fix: one sentence or no body. For a real change: a short paragraph.

Never anthropomorphize code. Never restate the subject in different words.

OUTPUT FORMAT — output ONLY the commit between these markers:
COMMIT_BEGIN
<commit message>
COMMIT_END
`;

  let fullPrompt = `${prompt}
RECENT COMMIT HISTORY:
${recentHistory}

DETAILED RECENT COMMITS (last 3):
${detailedRecent}`;

  if (repoGuidance) fullPrompt += `\n\nREPOSITORY GUIDANCE:${repoGuidance}`;

  fullPrompt += `\n\n---\n\nChanged files:\n${changedFiles
    .split("\n")
    .map((f) => `  - ${f}`)
    .join(
      "\n",
    )}\n\nGit stat: ${statSummary.split("\n").pop()}\n\nDIFF (${diffLines} lines):\n\`\`\`diff\n${actualDiff}\n\`\`\``;

  if (extraContext)
    fullPrompt += `\n\nAdditional context from developer: ${extraContext}`;

  const aiCmd =
    process.env.GIT_UPLOAD_AI_CMD ||
    'copilot -s --model gpt-5.1-codex --deny-tool write --deny-tool shell -p "$GIT_UPLOAD_AI_PROMPT"';

  const aiOutput = await new Promise((resolve, reject) => {
    let out = "";
    let err = "";
    const child = spawn("sh", ["-c", aiCmd], {
      env: { ...process.env, GIT_UPLOAD_AI_PROMPT: fullPrompt },
      cwd,
    });
    child.stdout.on("data", (d) => {
      out += d;
    });
    child.stderr.on("data", (d) => {
      err += d;
    });
    child.on("close", (code) => {
      if (code !== 0 || !out.trim())
        reject(
          new Error(
            `AI message generation failed (exit ${code}): ${err.trim()}`,
          ),
        );
      else resolve(out);
    });
  });

  // Parse COMMIT_BEGIN/COMMIT_END
  const lines = aiOutput.split("\n");
  let capturing = false;
  const msgLines = [];
  for (const line of lines) {
    if (line.trim() === "COMMIT_BEGIN") {
      capturing = true;
      continue;
    }
    if (line.trim() === "COMMIT_END") {
      capturing = false;
      break;
    }
    if (capturing) msgLines.push(line);
  }
  const commitMsg = msgLines.join("\n").trim();
  if (!commitMsg) {
    throw new Error(
      "Could not parse AI output. Use the message parameter to provide a manual message.",
    );
  }
  return commitMsg;
}

async function handleCheckpoint(args) {
  // Determine workspace root
  let cwd;
  try {
    cwd = await execGit(["rev-parse", "--show-toplevel"], process.cwd());
  } catch {
    // Fallback: __dirname is the script's location (workspace root)
    try {
      cwd = await execGit(["rev-parse", "--show-toplevel"], __dirname);
    } catch {
      throw new Error("Not inside a git repository.");
    }
  }

  // Check if checkpoint is enabled for this repo
  let enabled = "true";
  try {
    enabled = await execGit(["config", "--get", "checkpoint.enabled"], cwd);
  } catch {
    // Not set — default true
  }
  if (enabled === "false") {
    return [
      {
        type: "text",
        text: "[no-op] Checkpoint is disabled for this repo. Use `git checkpoint --enable` to turn on.",
      },
    ];
  }

  // Stage
  const stageAll = args.all !== false; // default true
  if (stageAll) {
    await execGit(["add", "-A"], cwd);
  }

  // Check if there's anything staged
  try {
    await execGit(["diff", "--cached", "--quiet"], cwd);
    // If the command succeeds, nothing is staged
    return [{ type: "text", text: "Nothing to commit — working tree clean." }];
  } catch {
    // Good — there are staged changes
  }

  // Get or generate commit message
  let message = String(args.message || "").trim();
  if (!message) {
    message = await generateAiCommitMessage(
      cwd,
      String(args.context || "").trim(),
    );
  }

  // Build commit args
  const commitArgs = ["commit", "-m", message];

  // GPG signing
  let signCommits = "false";
  try {
    signCommits = await execGit(["config", "--get", "checkpoint.sign"], cwd);
  } catch {
    // Not set
  }
  if (signCommits === "true") {
    commitArgs.push("-S");
  }

  // Commit
  await execGit(commitArgs, cwd);

  // Get the result
  const commitHash = await execGit(["rev-parse", "--short", "HEAD"], cwd);
  const oneline = await execGit(["log", "--oneline", "-1"], cwd);
  const stat = await execGit(["diff", "--stat", "HEAD~1..HEAD"], cwd);

  // Optional push
  let pushResult = "";
  const doPush = args.push === true;
  let pushDefault = "false";
  try {
    pushDefault = await execGit(["config", "--get", "checkpoint.push"], cwd);
  } catch {
    // Not set
  }
  if (doPush || pushDefault === "true") {
    try {
      await execGit(["push"], cwd);
      pushResult = "\nPushed to remote.";
    } catch (err) {
      pushResult = `\nPush failed: ${err.message}`;
    }
  }

  return [
    {
      type: "text",
      text: `Committed ${commitHash}\n${oneline}\n\n${stat}${pushResult}`,
    },
  ];
}

// ---------------------------------------------------------------------------
// Tools config — filter disabled tools per user preferences
// ---------------------------------------------------------------------------

const TOOLS_CONFIG_PATH = path.join(
  process.env.HOME || process.env.USERPROFILE || "",
  ".config",
  "git-shell-helpers-mcp",
  "tools.json",
);

function getEnabledTools() {
  try {
    const config = JSON.parse(fs.readFileSync(TOOLS_CONFIG_PATH, "utf8"));
    const disabled = new Set(config.disabledTools || []);
    if (disabled.size === 0) return ALL_TOOLS;
    return ALL_TOOLS.filter((t) => !disabled.has(t.name));
  } catch {
    return ALL_TOOLS;
  }
}

function isToolDisabled(toolName) {
  try {
    const config = JSON.parse(fs.readFileSync(TOOLS_CONFIG_PATH, "utf8"));
    const disabled = config.disabledTools || [];
    return disabled.includes(toolName);
  } catch {
    return false;
  }
}

// ---------------------------------------------------------------------------
// Protocol handler
// ---------------------------------------------------------------------------

async function handleRequest(request) {
  const { id, method } = request;

  if (method === "initialize") {
    send({
      jsonrpc: "2.0",
      id,
      result: {
        protocolVersion: MCP_VERSION,
        capabilities: { tools: {} },
        serverInfo: { name: "gsh", version: SERVER_VERSION },
      },
    });
    return;
  }

  if (method === "notifications/initialized") {
    return;
  }

  if (method === "tools/list") {
    send({
      jsonrpc: "2.0",
      id,
      result: { tools: getEnabledTools() },
    });
    return;
  }

  if (method === "tools/call") {
    const toolName = request.params?.name;
    const toolArguments = request.params?.arguments || {};

    // Guard: user may have disabled this tool mid-conversation via sidebar.
    // Return a clean no-op so the model doesn't error out or retry.
    // Exception: force=true on checkpoint overrides a mid-session disable
    // (used only when the user explicitly asked to checkpoint).
    const isForced = toolName === "checkpoint" && toolArguments.force === true;
    if (isToolDisabled(toolName) && !isForced) {
      send({
        jsonrpc: "2.0",
        id,
        result: {
          content: [
            {
              type: "text",
              text: `[no-op] The "${toolName}" tool was disabled by the user during this session. This is not an error — continue your current task normally. If the user explicitly asked for this action, recall with { "force": true } to override.`,
            },
          ],
        },
      });
      return;
    }

    try {
      // Built-in tools
      if (toolName === "checkpoint") {
        const content = await handleCheckpoint(toolArguments);
        send({ jsonrpc: "2.0", id, result: { content } });
        return;
      }

      // Delegated sub-module tools
      for (const mod of modules) {
        const content = await mod.handleToolCall(toolName, toolArguments);
        if (content) {
          send({ jsonrpc: "2.0", id, result: { content } });
          return;
        }
      }
    } catch (error) {
      const message = error instanceof Error ? error.message : String(error);
      sendError(id, -32603, message);
      return;
    }

    sendError(id, -32601, `Unknown tool: ${toolName}`);
    return;
  }

  sendError(id, -32601, `Unknown method: ${method}`);
}

// ---------------------------------------------------------------------------
// Stdio transport
// ---------------------------------------------------------------------------

const lineReader = readline.createInterface({
  input: process.stdin,
  crlfDelay: Infinity,
});

lineReader.on("line", async (line) => {
  if (!line.trim()) {
    return;
  }

  try {
    const request = JSON.parse(line);
    await handleRequest(request);
  } catch {
    sendError(null, -32700, "Parse error");
  }
});
