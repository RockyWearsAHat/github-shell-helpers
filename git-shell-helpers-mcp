async function resolveRepoRoot() {
  const candidates = [];
  if (process.env.GSH_WORKSPACE_ROOTS) {
    try {
      const roots = JSON.parse(process.env.GSH_WORKSPACE_ROOTS);
      if (Array.isArray(roots)) candidates.push(...roots);
    } catch {
      // ignore
    }
  }
  candidates.push(process.cwd(), __dirname);
  for (const dir of candidates.filter(Boolean)) {
    try {
      return await execGit(["rev-parse", "--show-toplevel"], dir);
    } catch {
      // not a git repo — try next
    }
  }
  throw new Error("Not inside a git repository.");
}

function worktreePath(branch) {
  // Sanitize branch name for use as directory name
  const safeName = branch.replace(/[^a-zA-Z0-9._-]/g, "-");
  return path.join(WORKTREE_BASE, safeName);
}

async function handleBranchSessionStart(args) {
  const { branch, base } = args;
  if (!branch) throw new Error("branch is required");

  const toplevel = await resolveRepoRoot();

  const wtPath = worktreePath(branch);

  // If worktree already exists and is valid, return it
  if (fs.existsSync(wtPath)) {
    try {
      const existing = await execGit(["rev-parse", "--show-toplevel"], wtPath);
      const existingBranch = await execGit(
        ["symbolic-ref", "--short", "HEAD"],
        wtPath,
      );
      const status = await execGit(["status", "--short"], wtPath);
      notifyWorkspaceFolderAdd(wtPath, existingBranch.trim());
      return [
        {
          type: "text",
          text: [
            `Branch session already active.`,
            `Path: ${existing}`,
            `Branch: ${existingBranch}`,
            `Status: ${status || "clean"}`,
            ``,
            `Use this path for all file operations and terminal commands.`,
          ].join("\n"),
        },
      ];
    } catch {
      // Stale worktree — remove and recreate
      try {
        await execGit(["worktree", "remove", "--force", wtPath], toplevel);
      } catch {
        // If git can't remove it, try filesystem cleanup
        fs.rmSync(wtPath, { recursive: true, force: true });
        try {
          await execGit(["worktree", "prune"], toplevel);
        } catch {
          // ignore
        }
      }
    }
  }

  // Ensure base directory exists
  fs.mkdirSync(WORKTREE_BASE, { recursive: true });

  // Check if branch exists
  let branchExists = false;
  try {
    await execGit(["rev-parse", "--verify", `refs/heads/${branch}`], toplevel);
    branchExists = true;
  } catch {
    // branch doesn't exist yet
  }

  if (branchExists) {
    // Create worktree for existing branch
    await execGit(["worktree", "add", wtPath, branch], toplevel);
  } else {
    // Create new branch and worktree
    const baseRef = base || "HEAD";
    await execGit(["worktree", "add", "-b", branch, wtPath, baseRef], toplevel);
  }

  const status = await execGit(["status", "--short", "--branch"], wtPath);

  // Notify VS Code extension to add worktree as workspace folder
  notifyWorkspaceFolderAdd(wtPath, branch);

  return [
    {
      type: "text",
      text: [
        `Branch session started.`,
        `Path: ${wtPath}`,
        `Branch: ${branch}`,
        `Created from: ${branchExists ? "(existing branch)" : base || "HEAD"}`,
        `Status:\n${status}`,
        ``,
        `Use this path for all file operations and terminal commands.`,
        `When done, call branch_session_end to commit and clean up.`,
      ].join("\n"),
    },
  ];
}

async function handleBranchSessionEnd(args) {
  const { branch, discard } = args;
  if (!branch) throw new Error("branch is required");

  const toplevel = await resolveRepoRoot();

  const wtPath = worktreePath(branch);

  if (!fs.existsSync(wtPath)) {
    return [
      {
        type: "text",
        text: `No active worktree found for branch '${branch}'. Nothing to clean up.`,
      },
    ];
  }

  // Check for uncommitted work
  let dirty = "";
  try {
    dirty = await execGit(["status", "--short"], wtPath);
  } catch {
    // ignore
  }

  let commitInfo = "";
  if (dirty && !discard) {
    // Auto-commit uncommitted changes
    try {
      await execGit(["add", "-A"], wtPath);
      await execGit(
        [
          "commit",
          "-m",
          `WIP: auto-commit from branch session end on '${branch}'`,
        ],
        wtPath,
      );
      commitInfo = `Auto-committed uncommitted changes on '${branch}'.`;
    } catch (err) {
      commitInfo = `Warning: could not auto-commit: ${err.message}`;
    }
  } else if (dirty && discard) {
    commitInfo = `Discarded uncommitted changes on '${branch}'.`;
  }

  // Get last commit info before removing
  let lastCommit = "";
  try {
    lastCommit = await execGit(["log", "--oneline", "-1"], wtPath);
  } catch {
    // ignore
  }

  // Notify VS Code extension to remove worktree workspace folder
  notifyWorkspaceFolderRemove(wtPath, branch);

  // Remove the worktree
  try {
    await execGit(["worktree", "remove", "--force", wtPath], toplevel);
  } catch {
    // Fallback: force filesystem removal + prune
    fs.rmSync(wtPath, { recursive: true, force: true });
    try {
      await execGit(["worktree", "prune"], toplevel);
    } catch {
      // ignore
    }
  }

  return [
    {
      type: "text",
      text: [
        `Branch session ended.`,
        `Branch: ${branch}`,
        commitInfo,
        lastCommit ? `Last commit: ${lastCommit}` : "",
        ``,
        `The branch and all its commits are preserved.`,
        `Merge into the baseline when ready.`,
      ]
        .filter(Boolean)
        .join("\n"),
    },
  ];
}

async function handleBranchReadFile(args) {
  const { branch, filePath } = args;
  if (!branch) throw new Error("branch is required");
  if (!filePath) throw new Error("filePath is required");

  const toplevel = await resolveRepoRoot();

  let content;
  try {
    content = await execGit(["show", `${branch}:${filePath}`], toplevel);
  } catch (err) {
    throw new Error(
      `Could not read '${filePath}' from branch '${branch}': ${err.message}`,
    );
  }

  let commitHash = "";
  try {
    commitHash = await execGit(["rev-parse", "--short", branch], toplevel);
  } catch {
    // ignore
  }

  return [
    {
      type: "text",
      text: `File: ${filePath}\nBranch: ${branch}${commitHash ? ` (${commitHash})` : ""}\n\n${content}`,
    },
  ];
}

async function handleBranchStatus() {
  const toplevel = await resolveRepoRoot();

  const sections = [];

  // Active worktrees
  let worktreeList = "";
  try {
    worktreeList = await execGit(["worktree", "list", "--porcelain"], toplevel);
  } catch {
    // ignore
  }

  if (worktreeList) {
    const worktrees = [];
    let current = {};
    for (const line of worktreeList.split("\n")) {
      if (line.startsWith("worktree ")) {
        if (current.path) worktrees.push(current);
        current = { path: line.slice(9) };
      } else if (line.startsWith("HEAD ")) {
        current.head = line.slice(5, 12);
      } else if (line.startsWith("branch ")) {
        current.branch = line.slice(7).replace("refs/heads/", "");
      } else if (line === "detached") {
        current.branch = "(detached)";
      } else if (line === "") {
        if (current.path) worktrees.push(current);
        current = {};
      }
    }
    if (current.path) worktrees.push(current);

    // Identify which are agent sessions (under WORKTREE_BASE)
    const agentWts = worktrees.filter((w) => w.path.startsWith(WORKTREE_BASE));
    const mainWt = worktrees.find((w) => !w.path.startsWith(WORKTREE_BASE));

    if (mainWt) {
      let mainStatus = "";
      try {
        mainStatus = await execGit(["status", "--short"], mainWt.path);
      } catch {
        // ignore
      }
      sections.push(
        `Main workspace:\n  Path: ${mainWt.path}\n  Branch: ${mainWt.branch || "(unknown)"}\n  Status: ${mainStatus || "clean"}`,
      );
    }

    if (agentWts.length > 0) {
      const wtLines = [];
      for (const wt of agentWts) {
        let status = "";
        try {
          status = await execGit(["status", "--short"], wt.path);
        } catch {
          status = "(inaccessible)";
        }
        let lastCommit = "";
        try {
          lastCommit = await execGit(["log", "--oneline", "-1"], wt.path);
        } catch {
          // ignore
        }
        wtLines.push(
          `  ${wt.branch || "(unknown)"}:\n    Path: ${wt.path}\n    Status: ${status || "clean"}\n    Last: ${lastCommit || "(no commits)"}`,
        );
      }
      sections.push(`Active branch sessions:\n${wtLines.join("\n")}`);
    } else {
      sections.push("Active branch sessions: none");
    }
  }

  // Local branches with latest commit
  let branches = "";
  try {
    branches = await execGit(
      [
        "branch",
        "-v",
        "--format=%(refname:short) %(objectname:short) %(subject)",
      ],
      toplevel,
    );
  } catch {
    // ignore
  }
  if (branches) {
    sections.push(`Local branches:\n${branches}`);
  }

  return [{ type: "text", text: sections.join("\n\n") }];
}

// Periodic GC — clean up orphaned worktrees older than 24 hours
function gcWorktrees() {
  if (!fs.existsSync(WORKTREE_BASE)) return;
  const ONE_DAY = 24 * 60 * 60 * 1000;
  try {
    const entries = fs.readdirSync(WORKTREE_BASE);
    for (const entry of entries) {
      const entryPath = path.join(WORKTREE_BASE, entry);
      try {
        const stat = fs.statSync(entryPath);
        if (Date.now() - stat.mtimeMs > ONE_DAY) {
          // Check if git still considers it a valid worktree
          try {
            execGit(["rev-parse", "--show-toplevel"], entryPath);
            // Still valid — skip
          } catch {
            // Not a valid git dir anymore — remove
            fs.rmSync(entryPath, { recursive: true, force: true });
          }
        }
      } catch {
        // ignore
      }
    }
  } catch {
    // ignore
  }
}

// Run GC on startup and every 6 hours
gcWorktrees();
setInterval(gcWorktrees, 6 * 60 * 60 * 1000).unref();

function execGit(args, cwd) {
  return new Promise((resolve, reject) => {
    execFile("git", args, { cwd, timeout: 30000 }, (err, stdout, stderr) => {
      if (err) {
        reject(new Error((stderr || err.message || "").trim()));
      } else {
        resolve((stdout || "").trim());
      }
    });
  });
}

async function generateAiCommitMessage(cwd, extraContext) {
  function gitOut(gitArgs) {
    return new Promise((resolve) => {
      execFile("git", gitArgs, { cwd, timeout: 15000 }, (err, stdout) => {
        resolve(err ? "" : (stdout || "").trim());
      });
    });
  }

  const changedFiles = await gitOut(["diff", "--cached", "--name-only"]);
  const statSummary = await gitOut(["diff", "--cached", "--stat"]);
  let actualDiff = await gitOut(["diff", "--cached", "--unified=3"]);
  const diffLines = actualDiff.split("\n").length;
  if (diffLines > 2000) {
    actualDiff =
      actualDiff.split("\n").slice(0, 2000).join("\n") +
      `\n(truncated — showing first 2000 of ${diffLines} lines)`;
  }

  const recentHistory = await gitOut([
    "log",
    "--oneline",
    "-10",
    "--no-decorate",
  ]);
  const detailedRecent = await gitOut([
    "log",
    "-3",
    "--pretty=format:--- %h (%ar) ---%n%s%n%n%b",
  ]);

  // Load repo guidance
  let repoGuidance = "";
  for (const gf of [
    ".github/COMMIT_GUIDELINES.md",
    ".github/commit_guidelines.md",
    ".github/COMMIT_MESSAGE.md",
    ".github/commit_message.md",
    ".github/copilot-instructions.md",
    "AGENTS.md",
    "CLAUDE.md",
    "CONTRIBUTING.md",
  ]) {
    try {
      const raw = fs.readFileSync(path.join(cwd, gf), "utf8");
      const snippet = raw.split("\n").slice(0, 120).join("\n").trim();
      if (snippet) repoGuidance += `\n--- ${gf} ---\n${snippet}\n`;
    } catch {
      /* not present */
    }
  }

  const prompt = `You are a commit message generator. Your ONLY job is to describe
the staged diff below. You have no knowledge of any other project, conversation,
or task. Every word in your message must come from what you see in the diff and
the commit history of THIS repository. Do not infer, hallucinate, or borrow
context from outside this prompt.

This is a CHECKPOINT commit — the developer is marking a meaningful moment:
something works now that did not before, a logical unit of work is complete,
or they are about to switch context. Frame the message accordingly.

CONTEXT MATTERS MOST:
Read the recent commit history below. Each commit is part of an ongoing thread.
Frame yours as the next step in that story. If the diff and the history look
unrelated to each other, trust the diff — it is the ground truth.

SUBJECT LINE:
One line, <= 72 chars. Say what the commit DOES or FIXES, not what
files it touches.

BODY:
Describe the situation, what you did, and why. Someone reading git blame
should understand the reasoning without opening the diff.

Do NOT use section headers like 'What changed:', 'Why this matters:', etc.
For a tiny fix: one sentence or no body. For a real change: a short paragraph.

Never anthropomorphize code. Never restate the subject in different words.

OUTPUT FORMAT — output ONLY the commit between these markers:
COMMIT_BEGIN
<commit message>
COMMIT_END
`;

  let fullPrompt = `${prompt}
RECENT COMMIT HISTORY:
${recentHistory}

DETAILED RECENT COMMITS (last 3):
${detailedRecent}`;

  if (repoGuidance) fullPrompt += `\n\nREPOSITORY GUIDANCE:${repoGuidance}`;

  fullPrompt += `\n\n---\n\nChanged files:\n${changedFiles
    .split("\n")
    .map((f) => `  - ${f}`)
    .join(
      "\n",
    )}\n\nGit stat: ${statSummary.split("\n").pop()}\n\nDIFF (${diffLines} lines):\n\`\`\`diff\n${actualDiff}\n\`\`\``;

  if (extraContext)
    fullPrompt += `\n\nAdditional context from developer: ${extraContext}`;

  const aiCmd =
    process.env.GIT_UPLOAD_AI_CMD ||
    'copilot -s --model gpt-5.1-codex --deny-tool write --deny-tool shell -p "$GIT_UPLOAD_AI_PROMPT"';

  const aiOutput = await new Promise((resolve, reject) => {
    let out = "";
    let err = "";
    const child = spawn("sh", ["-c", aiCmd], {
      env: { ...process.env, GIT_UPLOAD_AI_PROMPT: fullPrompt },
      cwd,
    });
    child.stdout.on("data", (d) => {
      out += d;
    });
    child.stderr.on("data", (d) => {
      err += d;
    });
    child.on("close", (code) => {
      if (code !== 0 || !out.trim())
        reject(
          new Error(
            `AI message generation failed (exit ${code}): ${err.trim()}`,
          ),
        );
      else resolve(out);
    });
  });

  // Parse COMMIT_BEGIN/COMMIT_END
  const lines = aiOutput.split("\n");
  let capturing = false;
  const msgLines = [];
  for (const line of lines) {
    if (line.trim() === "COMMIT_BEGIN") {
      capturing = true;
      continue;
    }
    if (line.trim() === "COMMIT_END") {
      capturing = false;
      break;
    }
    if (capturing) msgLines.push(line);
  }
  const commitMsg = msgLines.join("\n").trim();
  if (!commitMsg) {
    throw new Error(
      "Could not parse AI output. Use the message parameter to provide a manual message.",
    );
  }
  return commitMsg;
}

async function handleCheckpoint(args) {
  // Determine workspace root — prefer explicit cwd from caller, then
  // GSH_WORKSPACE_ROOTS (set by extension), then process.cwd(), then __dirname.
  let cwd;
  if (args.cwd) {
    try {
      cwd = await execGit(["rev-parse", "--show-toplevel"], args.cwd);
    } catch {
      throw new Error(
        `Specified cwd is not inside a git repository: ${args.cwd}`,
      );
    }
  } else {
    cwd = await resolveRepoRoot();
  }

  // Branch assertion — if the caller specified a branch, verify HEAD is on it.
  let currentBranch = "";
  try {
    currentBranch = await execGit(["symbolic-ref", "--short", "HEAD"], cwd);
  } catch {
    // Detached HEAD — currentBranch stays empty
  }
  if (args.branch) {
    if (!currentBranch) {
      throw new Error(
        `Branch assertion failed: HEAD is detached, expected branch '${args.branch}'. Switch to the correct branch before checkpointing.`,
      );
    }
    if (currentBranch !== args.branch) {
      throw new Error(
        `Branch assertion failed: HEAD is on '${currentBranch}', expected '${args.branch}'. Switch to the correct branch before checkpointing.`,
      );
    }
  }

  // Check if checkpoint is enabled for this repo
  let enabled = "true";
  try {
    enabled = await execGit(["config", "--get", "checkpoint.enabled"], cwd);
  } catch {
    // Not set — default true
  }
  if (enabled === "false") {
    return [
      {
        type: "text",
        text: "[no-op] Checkpoint is disabled for this repo. Use `git checkpoint --enable` to turn on.",
      },
    ];
  }

  // Stage
  const stageAll = args.all !== false; // default true
  if (stageAll) {
    await execGit(["add", "-A"], cwd);
  }

  // Check if there's anything staged
  try {
    await execGit(["diff", "--cached", "--quiet"], cwd);
    // If the command succeeds, nothing is staged
    return [{ type: "text", text: "Nothing to commit — working tree clean." }];
  } catch {
    // Good — there are staged changes
  }

  // Get or generate commit message
  let message = String(args.message || "").trim();
  if (!message) {
    message = await generateAiCommitMessage(
      cwd,
      String(args.context || "").trim(),
    );
  }

  // Build commit args
  const commitArgs = ["commit", "-m", message];

  // GPG signing
  let signCommits = "false";
  try {
    signCommits = await execGit(["config", "--get", "checkpoint.sign"], cwd);
  } catch {
    // Not set
  }
  if (signCommits === "true") {
    commitArgs.push("-S");
  }

  // Commit
  await execGit(commitArgs, cwd);

  // Get the result
  const commitHash = await execGit(["rev-parse", "--short", "HEAD"], cwd);
  const oneline = await execGit(["log", "--oneline", "-1"], cwd);
  const stat = await execGit(["diff", "--stat", "HEAD~1..HEAD"], cwd);

  // Optional push
  let pushResult = "";
  const doPush = args.push === true;
  let pushDefault = "false";
  try {
    pushDefault = await execGit(["config", "--get", "checkpoint.push"], cwd);
  } catch {
    // Not set
  }
  if (doPush || pushDefault === "true") {
    try {
      await execGit(["push"], cwd);
      pushResult = "\nPushed to remote.";
    } catch (err) {
      pushResult = `\nPush failed: ${err.message}`;
    }
  }

  const branchInfo = currentBranch
    ? ` on branch '${currentBranch}'`
    : " (detached HEAD)";
  return [
    {
      type: "text",
      text: `Committed ${commitHash}${branchInfo}\n${oneline}\n\n${stat}${pushResult}`,
    },
  ];
}

// ---------------------------------------------------------------------------
// Tools config — filter disabled tools per user preferences
// ---------------------------------------------------------------------------

const TOOLS_CONFIG_PATH = path.join(
  process.env.HOME || process.env.USERPROFILE || "",
  ".config",
  "git-shell-helpers-mcp",
  "tools.json",
);

function getEnabledTools() {
  try {
    const config = JSON.parse(fs.readFileSync(TOOLS_CONFIG_PATH, "utf8"));
    const disabled = new Set(config.disabledTools || []);
    if (disabled.size === 0) return ALL_TOOLS;
    return ALL_TOOLS.filter((t) => !disabled.has(t.name));
  } catch {
    return ALL_TOOLS;
  }
}

function isToolDisabled(toolName) {
  try {
    const config = JSON.parse(fs.readFileSync(TOOLS_CONFIG_PATH, "utf8"));
    const disabled = config.disabledTools || [];
    return disabled.includes(toolName);
  } catch {
    return false;
  }
}

// ---------------------------------------------------------------------------
// Protocol handler
// ---------------------------------------------------------------------------

async function handleRequest(request) {
  const { id, method } = request;

  if (method === "initialize") {
    send({
      jsonrpc: "2.0",
      id,
      result: {
        protocolVersion: MCP_VERSION,
        capabilities: { tools: {} },
        serverInfo: { name: "gsh", version: SERVER_VERSION },
      },
    });
    return;
  }

  if (method === "notifications/initialized") {
    return;
  }

  if (method === "tools/list") {
    notifySessionPulse();
    send({
      jsonrpc: "2.0",
      id,
      result: { tools: getEnabledTools() },
    });
    return;
  }

  if (method === "tools/call") {
    const toolName = request.params?.name;
    const toolArguments = request.params?.arguments || {};

    // Guard: user may have disabled this tool mid-conversation via sidebar.
    // Return a clean no-op so the model doesn't error out or retry.
    // Exception: force=true on checkpoint overrides a mid-session disable
    // (used only when the user explicitly asked to checkpoint).
    const isForced = toolName === "checkpoint" && toolArguments.force === true;
    if (isToolDisabled(toolName) && !isForced) {
      send({
        jsonrpc: "2.0",
        id,
        result: {
          content: [
            {
              type: "text",
              text: `[no-op] The "${toolName}" tool was disabled by the user during this session. This is not an error — continue your current task normally. If the user explicitly asked for this action, recall with { "force": true } to override.`,
            },
          ],
        },
      });
      return;
    }

    const actId = notifyActivityBegin(toolName, toolArguments);
    try {
      try {
        // Built-in tools
        if (toolName === "checkpoint") {
          const content = await handleCheckpoint(toolArguments);
          send({ jsonrpc: "2.0", id, result: { content } });
          return;
        }

        if (toolName === "workspace_context") {
          const content = await handleWorkspaceContext();
          send({ jsonrpc: "2.0", id, result: { content } });
          return;
        }

        if (toolName === "branch_session_start") {
          const content = await handleBranchSessionStart(toolArguments);
          send({ jsonrpc: "2.0", id, result: { content } });
          return;
        }

        if (toolName === "branch_session_end") {
          const content = await handleBranchSessionEnd(toolArguments);
          send({ jsonrpc: "2.0", id, result: { content } });
          return;
        }

        if (toolName === "branch_read_file") {
          const content = await handleBranchReadFile(toolArguments);
          send({ jsonrpc: "2.0", id, result: { content } });
          return;
        }

        if (toolName === "branch_status") {
          const content = await handleBranchStatus();
          send({ jsonrpc: "2.0", id, result: { content } });
          return;
        }

        if (toolName === "navigate_to_branch") {
          const content = await handleNavigateToBranch(toolArguments);
          send({ jsonrpc: "2.0", id, result: { content } });
          return;
        }

        // Delegated sub-module tools
        for (const mod of modules) {
          const content = await mod.handleToolCall(toolName, toolArguments);
          if (content) {
            send({ jsonrpc: "2.0", id, result: { content } });
            return;
          }
        }
      } catch (error) {
        const message = error instanceof Error ? error.message : String(error);
        sendError(id, -32603, message);
        return;
      }

      sendError(id, -32601, `Unknown tool: ${toolName}`);
    } finally {
      notifyActivityEnd(actId);
    }
    return;
  }

  sendError(id, -32601, `Unknown method: ${method}`);
}

// ---------------------------------------------------------------------------
// Stdio transport
// ---------------------------------------------------------------------------

const lineReader = readline.createInterface({
  input: process.stdin,
  crlfDelay: Infinity,
});

lineReader.on("line", async (line) => {
  if (!line.trim()) {
    return;
  }

  try {
    const request = JSON.parse(line);
    await handleRequest(request);
  } catch {
    sendError(null, -32700, "Parse error");
  }
});
