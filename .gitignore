.DS_Store
# Compiled C shim — platform-specific, built on install from gsh-mcp.c
gsh-mcp
# Native git-cs-grade — platform-specific, built on install from cs-grade/.
# The committed sources are cs-grade/ (Rust) and git-cs-grade.js (Node fallback).
/git-cs-grade
cs-grade/target/
# Native MCP tools — platform-specific, built on install from native/ (Rust).
# Rust-only: no Node fallback. The committed source is the native/ crate.
/gsh-native
native/target/
# Generated project index (cheap repo map) — rebuilt on demand by `gsh index`.
.gsh/index/
*.dxbundle
build/
coverage/
dist/
vscode-extension/*.vsix
vision-tool/*.vsix
vscode-extension/node_modules/
vision-tool/node_modules/
.vscode/aioserver-vision-ipc.json
.vscode/gsh-vision-ipc.json
.github/session-memory/*
!.github/session-memory/.gitkeep
.env
atlas-api/.env*-chat-history.jsonl
