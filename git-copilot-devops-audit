install_global_skills() {
	local skills_root="$SCRIPT_DIR/.github/skills"
	local target_root="$COPILOT_USER_DIR/skills"
	local source_skill
	local relative_dir
	local target_dir
	local target_skill

	if [ ! -d "$skills_root" ]; then
		return
	fi

	while IFS= read -r -d '' source_skill; do
		relative_dir="${source_skill#$skills_root/}"
		relative_dir="${relative_dir%/SKILL.md}"
		target_dir="$target_root/$relative_dir"
		target_skill="$target_dir/SKILL.md"
		mkdir -p "$target_dir"

		if [ -f "$target_skill" ] && [ "$install_force" = false ]; then
			ui_skip "$target_skill"
		else
			printf '%s\n' "$(cat "$source_skill")" > "$target_skill"
			ui_ok "User skill: $target_skill"
		fi
	done < <(find "$skills_root" -type f -name 'SKILL.md' -print0 2>/dev/null)
}

generate_research_cache_file() {
	local project="$1"
	cat <<EOF
# DevOps Audit Research Cache — ${project}

_Seeded by \
	\`git-copilot-devops-audit\` on $(date '+%Y-%m-%d %H:%M:%S')_

## Purpose

This file is a persistent research cache for the audit. It exists to carry forward useful evidence across audit runs without treating old research as permanently true.

Rules:
- Reuse prior research only when it is still fresh or has been revalidated.
- Prefer refreshing the most important stale evidence first.
- Replace or downgrade stale conclusions instead of endlessly appending more notes.
- Keep principles only when they still match current docs, recent repos, and recent videos.

## Freshness Policy

| Evidence Type | Importance | Refresh Target | Stale After | Notes |
|---|---|---:|---:|---|
| Official docs and model lists | Critical | 14 days | 30 days | Highest priority; docs win when they conflict with weaker sources |
