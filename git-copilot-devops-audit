# ── Generate audit context file ───────────────────────────────────────────────
generate_context_file() {
	local project="$1"
	local context=""

	context+="# DevOps Audit Context — ${project}\n\n"
	context+="_Generated by \`git-copilot-devops-audit\` on $(date '+%Y-%m-%d %H:%M:%S')_\n\n"

	# Project metadata
	context+="## Project Metadata\n\n"
	context+="- **Name:** ${project}\n"
	context+="- **Root:** \`${repo_root}\`\n"
	[ -n "$DETECTED_LANG_STR" ] && context+="- **Languages:** ${DETECTED_LANG_STR}\n"
	[ -n "$DETECTED_FRAMEWORK_STR" ] && context+="- **Frameworks:** ${DETECTED_FRAMEWORK_STR}\n"
	[ -n "$DETECTED_CI" ] && context+="- **CI/CD:** ${DETECTED_CI}\n"
	context+="\n"
	context+="$(build_inventory)\n"

	context+="---\n\n## Snapshot Purpose\n\n"
	context+="This file is a lightweight seed for the audit. It exists to point the context phase at the right files without replaying the full contents of every Copilot file into the runtime context. The context phase must still read the workspace directly and verify current file contents for itself.\n\n"

	context+="## Files The Context Phase Should Read\n\n"
	context+="### Project Understanding\n"
	context+="- \`README.md\`\n"
	[ -f "Makefile" ] && context+="- \`Makefile\`\n"
	[ -f "CMakeLists.txt" ] && context+="- \`CMakeLists.txt\`\n"
	[ -f "package.json" ] && context+="- \`package.json\`\n"
	[ -f "Cargo.toml" ] && context+="- \`Cargo.toml\`\n"
	[ -f "pyproject.toml" ] && context+="- \`pyproject.toml\`\n"
	[ -d ".github/workflows" ] && context+="- \`.github/workflows/\`\n"
	[ -f "CONTRIBUTING.md" ] && context+="- \`CONTRIBUTING.md\`\n"
	context+="\n### Copilot Files\n"

	[ -n "$COPILOT_MAIN" ] && context+="- \`$COPILOT_MAIN\`\n"
	for f in "${COPILOT_AGENTS[@]}"; do
		context+="- \`$f\`\n"
	done
	for f in "${COPILOT_INSTRUCTIONS[@]}"; do
		context+="- \`$f\`\n"
	done
	for f in "${COPILOT_PROMPTS[@]}"; do
		context+="- \`$f\`\n"
	done
	for f in "${COPILOT_SKILLS[@]}"; do
		context+="- \`$f\`\n"
	done
	[ -n "$COPILOT_PLAN" ] && context+="- \`$COPILOT_PLAN\`\n"
	[ -n "$COPILOT_BUGS" ] && context+="- \`$COPILOT_BUGS\`\n"
	[ -n "$COPILOT_MEMORY" ] && context+="- \`$COPILOT_MEMORY\`\n"
	[ -n "$COPILOT_AUDIT_RESEARCH" ] && context+="- \`$COPILOT_AUDIT_RESEARCH\`\n"
	[ -n "$COPILOT_AUDIT_COMMUNITY_SEED" ] && context+="- \`$COPILOT_AUDIT_COMMUNITY_SEED\`\n"

	if [ ${#MISPLACED_GITHUB_FILES[@]} -gt 0 ]; then
		context+="\n### Misplaced GitHub Customization Candidates\n"
		for f in "${MISPLACED_GITHUB_FILES[@]}"; do
			context+="- \`$f\` -> intended home \`$(intended_github_path "$f")\`\n"
			context+="  - external references: $(list_external_references "$f")\n"
		done
	fi

	context+="\n## Audit Expectations\n\n"
	context+="- Produce a compact context report, not a pasted-file transcript.\n"
	context+="- Inventory every Copilot-related file under .github exactly once.\n"
	context+="- Include enough project workflow detail that the research phase can stay external and the evaluation phase can stay file-by-file.\n"

	printf '%b' "$context"
}

# ── Main ──────────────────────────────────────────────────────────────────────
ui_title "git-copilot-devops-audit — $project_name"

echo ""
printf '%b  Stack:%b %s\n' "$DIM" "$NC" "${DETECTED_LANG_STR:-Unknown}"
[ -n "$DETECTED_FRAMEWORK_STR" ] && printf '%b  Frameworks:%b %s\n' "$DIM" "$NC" "$DETECTED_FRAMEWORK_STR"
printf '%b  Agents found:%b %d\n' "$DIM" "$NC" "${#COPILOT_AGENTS[@]}"
printf '%b  Instruction files found:%b %d\n' "$DIM" "$NC" "${#COPILOT_INSTRUCTIONS[@]}"
[ -z "$COPILOT_MAIN" ] && ui_warn "copilot-instructions.md not found — will be noted in audit"
echo ""

# Step 1: Write context file (skipped when --update-agent)
if [ "$update_agent" = false ]; then
	ui_step "Refreshing shared community cache bootstrap..."
	refresh_community_cache_bootstrap
	collect_copilot_files
	ui_step "Seeding audit research cache baseline..."
	seed_file_if_missing ".github/devops-audit-research.md" "$(generate_research_cache_file "$project_name")"
	[ -f ".github/devops-audit-research.md" ] && COPILOT_AUDIT_RESEARCH=".github/devops-audit-research.md"
	ui_step "Writing audit context snapshot..."
	write_file ".github/devops-audit-context.md" "$(generate_context_file "$project_name")"
else
	ui_step "Refreshing shared community cache bootstrap..."
	refresh_community_cache_bootstrap
	ui_info "Skipping context snapshot (--update-agent mode)"
fi

# Step 2: Install to standard user-level locations
VSCODE_USER_DIR="$HOME/Library/Application Support/Code/User"
COPILOT_USER_DIR="$HOME/.copilot"
if [ "$no_install" = false ]; then
	install_force=$force_mode
	[ "$update_agent" = true ] && install_force=true

	ui_step "Installing audit agents, router instruction, prompt, and skills to standard user locations..."
	mkdir -p "$COPILOT_USER_DIR/agents" "$COPILOT_USER_DIR/instructions" "$COPILOT_USER_DIR/skills" "$COPILOT_USER_DIR/prompts"

	agents_dir="$COPILOT_USER_DIR/agents"
	router_instruction="$COPILOT_USER_DIR/instructions/devops-audit-router.instructions.md"
	gsh_mcp_instruction="$COPILOT_USER_DIR/instructions/gsh-mcp-tools.instructions.md"
	prompts_dir="$COPILOT_USER_DIR/prompts"

	# Define all agent files to install
	typeset -A agent_generators=(
		[DevOpsAudit.agent.md]=generate_orchestrator_agent
		[DevOpsAuditContext.agent.md]=generate_context_agent
		[DevOpsAuditResearch.agent.md]=generate_research_agent
		[DevOpsAuditEvaluate.agent.md]=generate_evaluate_agent
		[DevOpsAuditImplement.agent.md]=generate_implement_agent
		[DevOpsAuditCommunitySubmit.agent.md]=generate_community_submit_agent
	)
	global_prompt="$prompts_dir/copilot-devops-audit.prompt.md"

	if [ "$dry_run" = true ]; then
		obsolete="$agents_dir/DevOpsAuditFix.agent.md"
		if [ -f "$obsolete" ]; then
			ui_info "[dry-run] Would remove obsolete: $obsolete"
		fi
		for name in "${(@k)agent_generators}"; do
			ui_info "[dry-run] Would write: $agents_dir/$name"
		done
		ui_info "[dry-run] Would write: $router_instruction"
		ui_info "[dry-run] Would write: $gsh_mcp_instruction"
		ui_info "[dry-run] Would write: $global_prompt"
	else
		obsolete="$agents_dir/DevOpsAuditFix.agent.md"
		if [ -f "$obsolete" ]; then
			rm -f "$obsolete"
			ui_ok "Removed obsolete agent: $obsolete"
		fi

		for name in "${(@k)agent_generators}"; do
			target="$agents_dir/$name"
			generator="${agent_generators[$name]}"
			if [ -f "$target" ] && [ "$install_force" = false ]; then
				ui_skip "$target"
			else
				printf '%s\n' "$($generator)" > "$target"
				ui_ok "User agent: $target"
			fi
		done

		if [ -f "$router_instruction" ] && [ "$install_force" = false ]; then
			ui_skip "$router_instruction"
		else
			printf '%s\n' "$(generate_router_instruction)" > "$router_instruction"
			ui_ok "User instruction: $router_instruction"
		fi

		if [ -f "$gsh_mcp_instruction" ] && [ "$install_force" = false ]; then
			ui_skip "$gsh_mcp_instruction"
		else
			printf '%s\n' "$(generate_gsh_mcp_tools_instruction)" > "$gsh_mcp_instruction"
			ui_ok "User instruction: $gsh_mcp_instruction"
		fi

		if [ -f "$global_prompt" ] && [ "$install_force" = false ]; then
			ui_skip "$global_prompt"
		else
			printf '%s\n' "$(generate_prompt_file)" > "$global_prompt"
			ui_ok "User prompt: $global_prompt"
		fi

		install_global_skills
	fi
fi

echo ""
ui_hr
if [ "$update_agent" = true ]; then
	printf '%b  ✅ Audit tooling updated in user locations%b\n' "$BOLD$GREEN" "$NC"
else
	printf '%b  ✅ Audit snapshot prepared for: %s%b\n' "$BOLD$GREEN" "$project_name" "$NC"
fi
ui_hr
echo ""
echo "  How to run the audit (works in ANY workspace):"
echo ""
if [ "$no_install" = false ]; then
	printf '  %b1.%b In VS Code Copilot Chat, type:\n' "$BOLD" "$NC"
	printf '       %b/copilot-devops-audit%b\n' "$CYAN" "$NC"
	printf '  %b  (the audit agents are private internal tooling; no workspace-local audit agent/prompt is created)%b\n' "$DIM" "$NC"
	echo ""
fi
printf '  %b2.%b To re-run with fresh context:\n' "$BOLD" "$NC"
printf '       %bgit copilot-devops-audit --force%b\n' "$CYAN" "$NC"
printf '  %b3.%b To update agent/prompt files only (no context snapshot):\n' "$BOLD" "$NC"
printf '       %bgit copilot-devops-audit --update-agent%b\n' "$CYAN" "$NC"
echo ""
if [ "$update_agent" = false ]; then
	printf '  %bAudit context saved to:%b .github/devops-audit-context.md\n' "$DIM" "$NC"
	printf '  %bAudit research cache:%b .github/devops-audit-research.md\n' "$DIM" "$NC"
	if [ -f ".github/devops-audit-community-seed.md" ]; then
		printf '  %bCommunity seed:%b .github/devops-audit-community-seed.md\n' "$DIM" "$NC"
	fi
fi
printf '  %bAudit results are returned in chat;%b repo-local support files are limited to the context snapshot, research cache, and pulled community bootstrap\n' "$DIM" "$NC"
printf '  %bAudit agents:%b %s/agents (mirrored to VS Code profile for discovery)\n' "$DIM" "$NC" "$COPILOT_USER_DIR"
printf '  %bAudit router:%b %s/instructions\n' "$DIM" "$NC" "$COPILOT_USER_DIR"
printf '  %bAudit skills:%b %s/skills\n' "$DIM" "$NC" "$COPILOT_USER_DIR"
printf '  %bAudit prompt:%b %s/prompts\n' "$DIM" "$NC" "$COPILOT_USER_DIR"
printf '  %bCommunity cache:%b %s/devops-audit-community-cache\n' "$DIM" "$NC" "$COPILOT_USER_DIR"
printf '  %bCommunity settings:%b %s/devops-audit-community-settings.json\n' "$DIM" "$NC" "$COPILOT_USER_DIR"
echo ""
ui_hr
echo ""
