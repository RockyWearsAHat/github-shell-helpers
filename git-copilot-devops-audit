#!/bin/zsh

# git-copilot-devops-audit
#
# Usage:
#   git-copilot-devops-audit [options]
#
# Description:
#   Installs a multi-agent audit system (orchestrator + 4 subagents), a
#   natural-language router, and a /copilot-devops-audit slash command for
#   VS Code Copilot use. The runtime audit should improve project-specific
#   Copilot customization while keeping the workspace artifacts limited to the
#   context snapshot and research cache that this command manages directly.
#
#   Architecture:
#     /copilot-devops-audit — Public deterministic slash-command entrypoint
#     devops-audit-router   — User-level best-effort natural-language router
#     DevOpsAuditContext    — Private worker: reads project and .github state
#     DevOpsAuditResearch   — Private worker: fetches docs, samples repos, validates model IDs
#     DevOpsAuditEvaluate   — Private worker: produces structured findings
#     DevOpsAuditImplement  — Private worker: applies targeted edits to .github/ files
#
#   The audit tooling is global on purpose. During an audit run, the orchestrator
#   may fully clean and rewrite anything under .github, but it must never modify
#   source files outside .github.
#
# Options:
#   -h, --help          Show this help message
#   -f, --force         Overwrite existing audit files without prompting
#   --no-install        Generate repo snapshot only, skip global agent/prompt install
#   --dry-run           Show what would be created without writing anything
#   -v, --verbose       Show file contents being embedded in the prompt
#   --update-agent      Refresh the global agents/router/prompt/skills only (skip context snapshot)
#
# Slash Command (installed globally):
#   Type /copilot-devops-audit in VS Code Copilot Chat
#
# Examples:
#   git-copilot-devops-audit                 # Install or refresh global audit tools
#   git-copilot-devops-audit --no-install    # Generate snapshot files only
#   git-copilot-devops-audit --update-agent  # Refresh global audit tools only

set -euo pipefail

export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:$PATH"

# ── Colors ──────────────────────────────────────────────────────────────────
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# ── UI helpers ───────────────────────────────────────────────────────────────
term_cols() { tput cols 2>/dev/null || echo 80; }

ui_hr() { printf '%s\n' "$(printf '%*s' "$(term_cols)" '' | tr ' ' '─')"; }

ui_title() {
	echo ""
	ui_hr
	printf '%b  %s%b\n' "$BOLD$CYAN" "$1" "$NC"
	ui_hr
}

ui_step() { printf '%b▶%b %s\n' "$BOLD$GREEN" "$NC" "$1"; }
ui_info() { printf '%b  %s%b\n' "$DIM" "$1" "$NC"; }
ui_warn() { printf '%b⚠  %s%b\n' "$YELLOW" "$1" "$NC"; }
ui_ok()   { printf '%b✓%b  %s\n' "$GREEN" "$NC" "$1"; }
ui_skip() { printf '%b–%b  %s %b(skipped)%b\n' "$DIM" "$NC" "$1" "$DIM" "$NC"; }

# ── Argument parsing ─────────────────────────────────────────────────────────
force_mode=false
no_install=false
dry_run=false
verbose=false
update_agent=false

for arg in "$@"; do
	case "$arg" in
		--force|-f)      force_mode=true ;;
		--no-install)    no_install=true ;;
		--dry-run)       dry_run=true ;;
		--verbose|-v)    verbose=true ;;
		--update-agent)  update_agent=true ;;
		--help|-h)
			sed -n '3,30p' "$0" | sed 's/^# \{0,1\}//'
			exit 0
			;;
		-*)
			echo "[git-copilot-devops-audit] Unknown option: $arg" >&2
			exit 1
			;;
	esac
done

# ── Require git repo ─────────────────────────────────────────────────────────
if ! git rev-parse --git-dir >/dev/null 2>&1; then
	echo "[git-copilot-devops-audit] Error: Not in a git repository." >&2
	exit 1
fi

repo_root=$(git rev-parse --show-toplevel 2>/dev/null)
cd "$repo_root"

# ── Project detection ────────────────────────────────────────────────────────
detect_project() {
	DETECTED_LANGS=()
	DETECTED_FRAMEWORKS=()
	DETECTED_BUILD_CMDS=()
	DETECTED_TEST_CMDS=()
	DETECTED_PKG_MANAGERS=()

	[ -f "Cargo.toml" ]                   && DETECTED_LANGS+=("Rust")       && DETECTED_BUILD_CMDS+=("cargo build")  && DETECTED_TEST_CMDS+=("cargo test")
	[ -f "go.mod" ]                        && DETECTED_LANGS+=("Go")         && DETECTED_BUILD_CMDS+=("go build ./...") && DETECTED_TEST_CMDS+=("go test ./...")
	[ -f "pyproject.toml" ] || [ -f "setup.py" ] || [ -f "requirements.txt" ] && DETECTED_LANGS+=("Python") && DETECTED_TEST_CMDS+=("pytest")
	[ -f "pom.xml" ]                       && DETECTED_LANGS+=("Java")       && DETECTED_BUILD_CMDS+=("mvn compile") && DETECTED_TEST_CMDS+=("mvn test")
	[ -f "build.gradle" ] || [ -f "build.gradle.kts" ] && DETECTED_LANGS+=("Kotlin/Java") && DETECTED_BUILD_CMDS+=("./gradlew build") && DETECTED_TEST_CMDS+=("./gradlew test")
	[ -f "mix.exs" ]                       && DETECTED_LANGS+=("Elixir")     && DETECTED_BUILD_CMDS+=("mix compile") && DETECTED_TEST_CMDS+=("mix test")
	[ -f "Gemfile" ]                        && DETECTED_LANGS+=("Ruby")       && DETECTED_TEST_CMDS+=("bundle exec rspec")
	[ -f "CMakeLists.txt" ]                && DETECTED_LANGS+=("C/C++")      && DETECTED_BUILD_CMDS+=("cmake --build build")
	[ -f "Makefile" ] || [ -f "makefile" ] && DETECTED_BUILD_CMDS+=("make")

	if [ -f "package.json" ]; then
		DETECTED_LANGS+=("JavaScript/TypeScript")
		grep -q '"react"'    package.json 2>/dev/null && DETECTED_FRAMEWORKS+=("React")
		grep -q '"next"'     package.json 2>/dev/null && DETECTED_FRAMEWORKS+=("Next.js")
		grep -q '"vue"'      package.json 2>/dev/null && DETECTED_FRAMEWORKS+=("Vue")
		grep -q '"svelte"'   package.json 2>/dev/null && DETECTED_FRAMEWORKS+=("Svelte")
		grep -q '"express"'  package.json 2>/dev/null && DETECTED_FRAMEWORKS+=("Express")
		grep -q '"fastify"'  package.json 2>/dev/null && DETECTED_FRAMEWORKS+=("Fastify")
		[ -f "package-lock.json" ] && DETECTED_PKG_MANAGERS+=("npm")
		[ -f "yarn.lock" ]         && DETECTED_PKG_MANAGERS+=("yarn")
		[ -f "pnpm-lock.yaml" ]    && DETECTED_PKG_MANAGERS+=("pnpm")
		[ -f "bun.lockb" ]         && DETECTED_PKG_MANAGERS+=("bun")
		DETECTED_BUILD_CMDS+=("npm run build")
		DETECTED_TEST_CMDS+=("npm test")
	fi

	# Shell scripts project
	if [ ${#DETECTED_LANGS[@]} -eq 0 ]; then
		find . -maxdepth 1 \( -name '*.sh' -o -name '*.zsh' -o -name '*.bash' \) -print -quit 2>/dev/null | grep -q . && DETECTED_LANGS+=("Shell/Zsh")
	fi

	# Detect CI
	DETECTED_CI=""
	[ -d ".github/workflows" ] && DETECTED_CI="GitHub Actions"
	[ -f ".circleci/config.yml" ] && DETECTED_CI="${DETECTED_CI:+$DETECTED_CI, }CircleCI"
	[ -f ".gitlab-ci.yml" ] && DETECTED_CI="${DETECTED_CI:+$DETECTED_CI, }GitLab CI"
	[ -f "Jenkinsfile" ] && DETECTED_CI="${DETECTED_CI:+$DETECTED_CI, }Jenkins"

	DETECTED_LANG_STR="${(j:, :)DETECTED_LANGS}"
	DETECTED_FRAMEWORK_STR="${(j:, :)DETECTED_FRAMEWORKS}"
}

detect_project

project_name=""
remote_url=$(git remote get-url origin 2>/dev/null || echo "")
[ -n "$remote_url" ] && project_name=$(basename "$remote_url" .git) || project_name=$(basename "$repo_root")

# ── Collect existing Copilot files ───────────────────────────────────────────
collect_copilot_files() {
	COPILOT_MAIN=""
	COPILOT_AGENTS=()
	COPILOT_INSTRUCTIONS=()
	COPILOT_PROMPTS=()
	COPILOT_SKILLS=()
	COPILOT_PLAN=""
	COPILOT_BUGS=""
	COPILOT_MEMORY=""
	COPILOT_AUDIT_RESEARCH=""
	COPILOT_AUDIT_COMMUNITY_SEED=""
	MISPLACED_GITHUB_FILES=()

	[ -f ".github/copilot-instructions.md" ] && COPILOT_MAIN=".github/copilot-instructions.md"
	[ -f ".github/plan.md" ]                 && COPILOT_PLAN=".github/plan.md"
	[ -f ".github/bugs.md" ]                 && COPILOT_BUGS=".github/bugs.md"
	[ -f ".github/instructions/memory.md" ]  && COPILOT_MEMORY=".github/instructions/memory.md"
	[ -f ".github/devops-audit-research.md" ] && COPILOT_AUDIT_RESEARCH=".github/devops-audit-research.md"
	[ -f ".github/devops-audit-community-seed.md" ] && COPILOT_AUDIT_COMMUNITY_SEED=".github/devops-audit-community-seed.md"

	if [ -d ".github/agents" ]; then
		setopt nullglob
		for f in .github/agents/*.md; do
			[ -f "$f" ] && COPILOT_AGENTS+=("$f")
		done
		unsetopt nullglob
	fi

	if [ -d ".github/instructions" ]; then
		setopt nullglob
		for f in .github/instructions/*.md; do
			[ -f "$f" ] && COPILOT_INSTRUCTIONS+=("$f")
		done
		unsetopt nullglob
	fi

	if [ -d ".github/prompts" ]; then
		setopt nullglob
		for f in .github/prompts/*.md; do
			[ -f "$f" ] && COPILOT_PROMPTS+=("$f")
		done
		unsetopt nullglob
	fi

	if [ -d ".github/skills" ]; then
		while IFS= read -r -d '' f; do
			COPILOT_SKILLS+=("${f#./}")
		done < <(find .github/skills -type f -name 'SKILL.md' -print0 2>/dev/null)
	fi

	while IFS= read -r -d '' f; do
		MISPLACED_GITHUB_FILES+=("${f#./}")
	done < <(
		find . \
			-path './.git' -prune -o \
			-path './.github' -prune -o \
			-type f \( \
				-name 'copilot-instructions.md' -o \
				-name '*.agent.md' -o \
				-name '*.prompt.md' -o \
				-name '*.instructions.md' -o \
				-name 'SKILL.md' \
			\) -print0 2>/dev/null
	)
}

collect_copilot_files

# ── Helpers ───────────────────────────────────────────────────────────────────
write_file() {
	local path="$1"
	local content="$2"

	if [ "$dry_run" = true ]; then
		ui_info "[dry-run] Would write: $path"
		return
	fi

	local dir
	dir=$(dirname "$path")
	mkdir -p "$dir"

	if [ -f "$path" ] && [ "$force_mode" = false ]; then
		ui_skip "$path"
		return
	fi

	printf '%s\n' "$content" > "$path"
	ui_ok "Written: $path"
}

seed_file_if_missing() {
	local path="$1"
	local content="$2"

	if [ -f "$path" ]; then
		ui_skip "$path"
		return
	fi

	if [ "$dry_run" = true ]; then
		ui_info "[dry-run] Would seed: $path"
		return
	fi

	local dir
	dir=$(dirname "$path")
	mkdir -p "$dir"
	printf '%s\n' "$content" > "$path"
	ui_ok "Seeded: $path"
}

seed_global_community_settings() {
	local settings_file="$HOME/.copilot/devops-audit-community-settings.json"
	local default_repo
	local default_local_clone=""
	local existing_json=""
	local merged_json=""

	default_repo="$(resolve_default_community_repo)"
	default_local_clone="$(resolve_default_local_clone)"

	if [ -f "$settings_file" ] && ! command -v jq >/dev/null 2>&1; then
		return
	fi

	if [ "$dry_run" = true ]; then
		ui_info "[dry-run] Would seed: $settings_file"
		return
	fi

	mkdir -p "$(dirname "$settings_file")"
	if [ -f "$settings_file" ]; then
		existing_json="$(cat "$settings_file")"
		merged_json="$(printf '%s' "$existing_json" | jq \
			--arg repo "$default_repo" \
			--arg clone "$default_local_clone" \
			'.schemaVersion = 1
			| .mode = (.mode // "pull-and-auto-submit")
			| .baseBranch = (.baseBranch // "main")
			| .branchPrefix = (.branchPrefix // "automation/community-cache-submission")
			| .communityRepo = (.communityRepo // $repo)
			| if $clone != "" then .localClone = (.localClone // $clone) else . end
			| .whitelistedRepos = (.whitelistedRepos // [])')"
	else
		merged_json="$(jq -n \
			--arg repo "$default_repo" \
			--arg clone "$default_local_clone" \
			'{
			  schemaVersion: 1,
			  mode: "pull-and-auto-submit",
			  communityRepo: $repo,
			  baseBranch: "main",
			  branchPrefix: "automation/community-cache-submission",
			  whitelistedRepos: []
			} | if $clone != "" then .localClone = $clone else . end')"
	fi
	printf '%s\n' "$merged_json" > "$settings_file"
	ui_ok "Seeded: $settings_file"
}

resolve_default_community_repo() {
	local manifest_file="$repo_root/community-cache/manifest.json"
	local remote_url=""
	local repo_name=""

	if command -v jq >/dev/null 2>&1 && [ -f "$manifest_file" ]; then
		repo_name="$(jq -r '.defaultCommunityRepo // ""' "$manifest_file")"
		[ -n "$repo_name" ] && printf '%s' "$repo_name" && return
	fi

	remote_url="$(git -C "$repo_root" remote get-url origin 2>/dev/null || true)"
	if [ -n "$remote_url" ]; then
		repo_name="$(printf '%s' "$remote_url" | sed -E 's#^[^:]+:##; s#^https?://[^/]+/##; s#\.git$##')"
		[ -n "$repo_name" ] && printf '%s' "$repo_name" && return
	fi

	printf '%s' "RockyWearsAHat/github-shell-helpers"
}

resolve_default_local_clone() {
	if [ -f "$repo_root/community-cache/manifest.json" ]; then
		printf '%s' "$repo_root"
		return
	fi

	printf ''
}

refresh_community_cache_bootstrap() {
	local helper_script="$SCRIPT_DIR/scripts/community-cache-pull.sh"
	local helper_cmd="git-copilot-devops-audit-community-pull"
	local target_workspace=""

	seed_global_community_settings

	if [ "$update_agent" = false ]; then
		target_workspace="$repo_root"
	fi

	if [ "$dry_run" = true ]; then
		if [ -n "$target_workspace" ]; then
			ui_info "[dry-run] Would refresh community cache for $target_workspace"
		else
			ui_info "[dry-run] Would refresh community cache"
		fi
		return
	fi

	if [ -x "$helper_script" ]; then
		if [ -n "$target_workspace" ]; then
			"$helper_script" --workspace "$target_workspace" >/dev/null 2>&1 || ui_warn "Community cache refresh failed; continuing without refreshed bootstrap"
		else
			"$helper_script" >/dev/null 2>&1 || ui_warn "Community cache refresh failed; continuing without refreshed bootstrap"
		fi
		return
	fi

	if command -v "$helper_cmd" >/dev/null 2>&1; then
		if [ -n "$target_workspace" ]; then
			"$helper_cmd" --workspace "$target_workspace" >/dev/null 2>&1 || ui_warn "Community cache refresh failed; continuing without refreshed bootstrap"
		else
			"$helper_cmd" >/dev/null 2>&1 || ui_warn "Community cache refresh failed; continuing without refreshed bootstrap"
		fi
		return
	fi

	ui_warn "Community cache pull helper was not found; continuing without refreshed bootstrap"
}

embed_file() {
	local label="$1"
	local path="$2"
	local lang="${3:-}"

	if [ -f "$path" ]; then
		[ "$verbose" = true ] && ui_info "  Embedding: $path"
		printf '\n### %s\n\n**File:** `%s`\n\n```%s\n%s\n```\n' \
			"$label" "$path" "$lang" "$(cat "$path")"
	else
		printf '\n### %s\n\n**File:** `%s` — _not found / not yet created_\n' \
			"$label" "$path"
	fi
}

intended_github_path() {
	local candidate="$1"
	local base
	base=$(basename "$candidate")

	case "$base" in
		copilot-instructions.md)
			printf '%s' ".github/copilot-instructions.md"
			;;
		*.agent.md)
			printf '%s' ".github/agents/$base"
			;;
		*.prompt.md)
			printf '%s' ".github/prompts/$base"
			;;
		*.instructions.md)
			printf '%s' ".github/instructions/$base"
			;;
		SKILL.md)
			printf '%s' ".github/skills/$(basename "$(dirname "$candidate")")/SKILL.md"
			;;
		*)
			printf '%s' ".github/$base"
			;;
	esac
}

list_external_references() {
	local candidate="$1"
	local candidate_name
	candidate_name=$(basename "$candidate")
	local hits=()
	local hit

	while IFS= read -r hit; do
		[ -z "$hit" ] && continue
		hit="${hit#./}"
		[ "$hit" = "$candidate" ] && continue
		hits+=("$hit")
	done < <(rg -l -F -g '!.github/**' -g '!.git/**' -g "!$candidate" -- "$candidate" . 2>/dev/null)

	while IFS= read -r hit; do
		[ -z "$hit" ] && continue
		hit="${hit#./}"
		[ "$hit" = "$candidate" ] && continue
		case " ${(j: :)hits} " in
			*" $hit "*) continue ;;
		esac
		hits+=("$hit")
	done < <(rg -l -F -g '!.github/**' -g '!.git/**' -g "!$candidate" -- "$candidate_name" . 2>/dev/null)

	if [ ${#hits[@]} -eq 0 ]; then
		printf '%s' "none"
		return
	fi

	printf '%s' "${(j:, :)hits}"
}

# ── Build file inventory section ──────────────────────────────────────────────
build_inventory() {
	local inv=""

	inv+="## Current Copilot Setup Inventory\n\n"

	# Main instructions
	if [ -n "$COPILOT_MAIN" ]; then
		inv+="- **copilot-instructions.md**: PRESENT\n"
	else
		inv+="- **copilot-instructions.md**: MISSING ← must be created\n"
	fi

	# Agents
	if [ ${#COPILOT_AGENTS[@]} -gt 0 ]; then
		inv+="- **Agents (${#COPILOT_AGENTS[@]}):**\n"
		for f in "${COPILOT_AGENTS[@]}"; do
			inv+="  - \`$f\`\n"
		done
	else
		inv+="- **Agents:** NONE FOUND\n"
	fi

	# Instructions
	if [ ${#COPILOT_INSTRUCTIONS[@]} -gt 0 ]; then
		inv+="- **Instruction files (${#COPILOT_INSTRUCTIONS[@]}):**\n"
		for f in "${COPILOT_INSTRUCTIONS[@]}"; do
			inv+="  - \`$f\`\n"
		done
	else
		inv+="- **Instruction files:** NONE FOUND\n"
	fi

	# Prompts
	if [ ${#COPILOT_PROMPTS[@]} -gt 0 ]; then
		inv+="- **Prompt files (${#COPILOT_PROMPTS[@]}):**\n"
		for f in "${COPILOT_PROMPTS[@]}"; do
			inv+="  - \`$f\`\n"
		done
	else
		inv+="- **Prompt files:** NONE\n"
	fi

	# Skills
	if [ ${#COPILOT_SKILLS[@]} -gt 0 ]; then
		inv+="- **Skills (${#COPILOT_SKILLS[@]}):**\n"
		for f in "${COPILOT_SKILLS[@]}"; do
			inv+="  - \`$f\`\n"
		done
	else
		inv+="- **Skills:** NONE FOUND\n"
	fi

	# Misplaced GitHub customization files
	if [ ${#MISPLACED_GITHUB_FILES[@]} -gt 0 ]; then
		inv+="- **Misplaced GitHub customization files (${#MISPLACED_GITHUB_FILES[@]}):**\n"
		for f in "${MISPLACED_GITHUB_FILES[@]}"; do
			inv+="  - \`$f\` -> intended home \`$(intended_github_path "$f")\`\n"
			inv+="    - external references: $(list_external_references "$f")\n"
		done
	else
		inv+="- **Misplaced GitHub customization files:** NONE FOUND\n"
	fi

	# CI
	[ -n "$DETECTED_CI" ] && inv+="- **CI/CD:** $DETECTED_CI\n" || inv+="- **CI/CD:** NONE DETECTED\n"
	[ -n "$COPILOT_AUDIT_RESEARCH" ] && inv+="- **Audit research cache:** PRESENT\n" || inv+="- **Audit research cache:** MISSING ← baseline will be seeded\n"
	[ -n "$COPILOT_AUDIT_COMMUNITY_SEED" ] && inv+="- **Community cache seed:** PRESENT\n" || inv+="- **Community cache seed:** MISSING ← will refresh when shared cache pull succeeds\n"

	printf '%b' "$inv"
}

