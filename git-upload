#!/usr/bin/env bash

# git-upload
#
# Usage:
#   git-upload [-ai|--aiDiffCommitMsg [ai-context]] [commit message]
#
# Behaviour:
#   - If --aiDiffCommitMsg / -ai is passed, the script will generate a commit
#     message from the current diff using GitHub Copilot CLI by default.
#   - The first non-flag argument after -ai (if any) is treated as optional
#     extra context to append to the default AI prompt.
#   - The next non-flag argument (if any) is used as a fallback/manual
#     commit message if AI is unavailable or fails.
#   - Without -ai, the first non-flag argument is the commit message,
#     defaulting to "default commit message".
#
# AI integration:
#   Default behaviour (no configuration needed as long as `copilot` is
#   installed and on PATH):
#     - The script builds a prompt like:
#         "examine differences between the last known push to this repository
#          and the current state, write a clean concise one-three line message
#          for this diff"
#       and, if you provided [ai-context] after -ai, appends that text.
#     - It then calls GitHub Copilot CLI non-interactively (write/shell tools denied):
#         copilot -s --deny-tool write --deny-tool shell -p "$GIT_UPLOAD_AI_PROMPT"
#
#   Advanced: you may optionally override the full AI command via
#   GIT_UPLOAD_AI_CMD for a single shell/session, but this is not required.

set -euo pipefail

use_ai=false
user_msg=""
ai_extra_context=""

DEFAULT_AI_CMD='copilot -s --model gpt-5.1-codex --deny-tool write --deny-tool shell -p "$GIT_UPLOAD_AI_PROMPT"'

# ── Library loading ────────────────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/lib/upload-spinner.sh"
source "${SCRIPT_DIR}/lib/upload-test-detection.sh"
source "${SCRIPT_DIR}/lib/upload-test-output.sh"
source "${SCRIPT_DIR}/lib/upload-diff-analysis.sh"
source "${SCRIPT_DIR}/lib/upload-ai-message.sh"

# Cleanup spinner on exit
trap 'stop_spinner' EXIT INT TERM

# ── Argument parsing ──────────────────────────────────────────────────
expect_ai_context_next=false

for arg in "$@"; do
	case "$arg" in
		--aiDiffCommitMsg|-ai)
			use_ai=true
			expect_ai_context_next=true
			;;
		--*)
			# Ignore other flags for now
			;;
		*)
			if [ "$expect_ai_context_next" = true ]; then
				# This non-flag arg immediately after -ai/--aiDiffCommitMsg
				# is treated as optional extra AI context.
				ai_extra_context="$arg"
				expect_ai_context_next=false
			elif [ -z "$user_msg" ]; then
				user_msg="$arg"
			fi
			;;
	esac
done



# ── Main ──────────────────────────────────────────────────────────────
main() {
	local GIT_DIR
	GIT_DIR=$(git rev-parse --git-dir 2>/dev/null || echo ".git")

	# ── Phase 0: Recover from broken / in-progress git operations ──────
	# Detect and attempt to resolve leftover state from interrupted
	# operations (rebase, merge, cherry-pick, revert, bisect, am).
	# With -ai, we try harder to auto-resolve; without it, we still
	# attempt safe recovery but bail on conflicts.

	# --- Bisect in progress ---
	if [ -f "$GIT_DIR/BISECT_LOG" ]; then
		echo "[git-upload] ⚠️  A bisect session is in progress." >&2
		echo "[git-upload] Resetting bisect to return to your branch…" >&2
		git bisect reset >/dev/null 2>&1 || {
			echo "[git-upload] Failed to reset bisect. Run 'git bisect reset' manually." >&2
			exit 1
		}
		echo "[git-upload] ✅ Bisect session ended." >&2
	fi

	# --- git am (mailbox apply) in progress ---
	# Check BEFORE the rebase block because git-am also uses rebase-apply/.
	if [ -d "$GIT_DIR/rebase-apply" ] && [ -f "$GIT_DIR/rebase-apply/applying" ]; then
		echo "[git-upload] ⚠️  A 'git am' patch application is in progress. Aborting…" >&2
		git am --abort >/dev/null 2>&1 || true
		echo "[git-upload] ✅ Patch application aborted." >&2
	fi

	# --- Rebase in progress ---
	if [ -d "$GIT_DIR/rebase-merge" ] || { [ -d "$GIT_DIR/rebase-apply" ] && [ ! -f "$GIT_DIR/rebase-apply/applying" ]; }; then
		echo "[git-upload] ⚠️  A rebase is in progress." >&2
		if git diff --quiet 2>/dev/null && git diff --cached --quiet 2>/dev/null; then
			# No conflicting files — try to continue
			echo "[git-upload] No conflicts detected. Attempting to continue rebase…" >&2
			if git rebase --continue >/dev/null 2>&1; then
				echo "[git-upload] ✅ Rebase completed successfully." >&2
			else
				echo "[git-upload] Rebase --continue failed. Aborting rebase to preserve your work…" >&2
				git rebase --abort >/dev/null 2>&1 || true
				echo "[git-upload] ✅ Rebase aborted. Your branch is back to its pre-rebase state." >&2
			fi
		else
			# There are conflicts or uncommitted changes
			if [ "$use_ai" = true ]; then
				# With -ai, attempt to resolve conflicts
				local conflict_files
				conflict_files=$(git diff --name-only --diff-filter=U 2>/dev/null || true)
				if [ -n "$conflict_files" ]; then
					echo "[git-upload] Conflict files detected during rebase:" >&2
					printf '%s\n' "$conflict_files" | sed 's/^/  - /' >&2
					echo "[git-upload] Attempting auto-resolution (accepting your rebased changes for conflicted files)…" >&2
					printf '%s\n' "$conflict_files" | while IFS= read -r cf; do
						[ -n "$cf" ] && git checkout --theirs -- "$cf" 2>/dev/null && git add "$cf" 2>/dev/null
					done
					if git rebase --continue >/dev/null 2>&1; then
						echo "[git-upload] ✅ Rebase completed after auto-resolving conflicts." >&2
					else
						echo "[git-upload] Auto-resolution insufficient. Aborting rebase…" >&2
						git rebase --abort >/dev/null 2>&1 || true
						echo "[git-upload] ✅ Rebase aborted safely." >&2
					fi
				else
					echo "[git-upload] Uncommitted changes exist mid-rebase. Aborting rebase…" >&2
					git rebase --abort >/dev/null 2>&1 || true
					echo "[git-upload] ✅ Rebase aborted safely." >&2
				fi
			else
				echo "[git-upload] Aborting in-progress rebase to preserve your work…" >&2
				git rebase --abort >/dev/null 2>&1 || true
				echo "[git-upload] ✅ Rebase aborted. Use -ai for automatic conflict resolution." >&2
			fi
		fi
	fi

	# --- Merge in progress ---
	if [ -f "$GIT_DIR/MERGE_HEAD" ]; then
		echo "[git-upload] ⚠️  A merge is in progress." >&2
		local merge_conflicts
		merge_conflicts=$(git diff --name-only --diff-filter=U 2>/dev/null || true)
		if [ -z "$merge_conflicts" ]; then
			# Merge is resolved but not committed
			echo "[git-upload] Merge appears resolved. Continuing…" >&2
		elif [ "$use_ai" = true ]; then
			echo "[git-upload] Merge conflicts detected:" >&2
			printf '%s\n' "$merge_conflicts" | sed 's/^/  - /' >&2
			echo "[git-upload] Attempting auto-resolution (accept incoming changes)…" >&2
			printf '%s\n' "$merge_conflicts" | while IFS= read -r cf; do
				[ -n "$cf" ] && git checkout --theirs -- "$cf" 2>/dev/null && git add "$cf" 2>/dev/null
			done
			local remaining_conflicts
			remaining_conflicts=$(git diff --name-only --diff-filter=U 2>/dev/null || true)
			if [ -n "$remaining_conflicts" ]; then
				echo "[git-upload] Could not resolve all merge conflicts. Aborting merge…" >&2
				git merge --abort >/dev/null 2>&1 || true
				echo "[git-upload] ✅ Merge aborted. Resolve conflicts manually and retry." >&2
			else
				echo "[git-upload] ✅ All merge conflicts resolved." >&2
			fi
		else
			echo "[git-upload] Merge has unresolved conflicts. Aborting merge…" >&2
			git merge --abort >/dev/null 2>&1 || true
			echo "[git-upload] ✅ Merge aborted. Use -ai for automatic conflict resolution." >&2
		fi
	fi

	# --- Cherry-pick in progress ---
	if [ -f "$GIT_DIR/CHERRY_PICK_HEAD" ]; then
		echo "[git-upload] ⚠️  A cherry-pick is in progress." >&2
		local cp_conflicts
		cp_conflicts=$(git diff --name-only --diff-filter=U 2>/dev/null || true)
		if [ -z "$cp_conflicts" ]; then
			echo "[git-upload] Cherry-pick appears resolved. Continuing…" >&2
			git cherry-pick --continue >/dev/null 2>&1 || {
				echo "[git-upload] Cherry-pick --continue failed. Aborting…" >&2
				git cherry-pick --abort >/dev/null 2>&1 || true
			}
		elif [ "$use_ai" = true ]; then
			echo "[git-upload] Cherry-pick conflicts detected:" >&2
			printf '%s\n' "$cp_conflicts" | sed 's/^/  - /' >&2
			echo "[git-upload] Attempting auto-resolution…" >&2
			printf '%s\n' "$cp_conflicts" | while IFS= read -r cf; do
				[ -n "$cf" ] && git checkout --theirs -- "$cf" 2>/dev/null && git add "$cf" 2>/dev/null
			done
			if git cherry-pick --continue >/dev/null 2>&1; then
				echo "[git-upload] ✅ Cherry-pick completed after auto-resolving conflicts." >&2
			else
				echo "[git-upload] Auto-resolution insufficient. Aborting cherry-pick…" >&2
				git cherry-pick --abort >/dev/null 2>&1 || true
			fi
		else
			echo "[git-upload] Cherry-pick has unresolved conflicts. Aborting…" >&2
			git cherry-pick --abort >/dev/null 2>&1 || true
			echo "[git-upload] ✅ Cherry-pick aborted. Use -ai for automatic resolution." >&2
		fi
	fi

	# --- Revert in progress ---
	if [ -f "$GIT_DIR/REVERT_HEAD" ]; then
		echo "[git-upload] ⚠️  A revert is in progress." >&2
		local rv_conflicts
		rv_conflicts=$(git diff --name-only --diff-filter=U 2>/dev/null || true)
		if [ -z "$rv_conflicts" ]; then
			echo "[git-upload] Revert appears resolved. Continuing…" >&2
			git revert --continue >/dev/null 2>&1 || {
				echo "[git-upload] Revert --continue failed. Aborting…" >&2
				git revert --abort >/dev/null 2>&1 || true
			}
		else
			echo "[git-upload] Revert has conflicts. Aborting to preserve work…" >&2
			git revert --abort >/dev/null 2>&1 || true
		fi
	fi

	# ── Phase 1: Resolve detached HEAD ─────────────────────────────────
	# Determine current branch and ensure we're not in detached HEAD.
	# NOTE: `git rev-parse --abbrev-ref HEAD` can yield surprising output in
	# brand-new repos (unborn branch / no commits yet). `git symbolic-ref` is
	# the reliable way to identify the branch HEAD points to.
	current_branch=$(git symbolic-ref -q --short HEAD 2>/dev/null || echo "")
	if [ -z "$current_branch" ]; then
		# HEAD is detached (or otherwise not a symbolic ref).
		head_commit=$(git rev-parse -q --verify HEAD 2>/dev/null || echo "")
		if [ -z "$head_commit" ]; then
			echo "[git-upload] HEAD is not on a branch (and there are no commits yet)." >&2
			echo "[git-upload] Fix: create/switch to a branch first (for example: 'git switch -c main')." >&2
			exit 1
		fi

		# If the detached commit is already contained by exactly one local branch,
		# we can safely switch to it without losing work.
		# Filter out entries that aren't real branch names (e.g., "(HEAD detached from ...)")
		containing_branches=$(git branch --contains "$head_commit" --format='%(refname:short)' 2>/dev/null \
			| grep -v '^(' \
			| sed '/^$/d' || echo "")
		containing_count=$(printf '%s\n' "$containing_branches" | sed '/^$/d' | wc -l | tr -d ' ')

		if [ "$containing_count" = "1" ]; then
			current_branch=$(printf '%s\n' "$containing_branches" | sed -n '1p')
			echo "[git-upload] Detached HEAD is contained by '$current_branch'; switching to that branch…" >&2
			git switch "$current_branch" >/dev/null 2>&1 || {
				echo "[git-upload] Failed to switch to '$current_branch'." >&2
				exit 1
			}
		elif [ "$containing_count" = "0" ]; then
			# Detached HEAD with commits not on any branch - create a branch to preserve work
			short_hash=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
			timestamp=$(date +%Y%m%d-%H%M%S)
			new_branch="detached-work-${short_hash}-${timestamp}"
			echo "[git-upload] You are in a detached HEAD state with commits not on any branch." >&2
			echo "[git-upload] Creating branch '$new_branch' to preserve your work…" >&2
			git switch -c "$new_branch" >/dev/null 2>&1 || {
				echo "[git-upload] Failed to create branch '$new_branch'." >&2
				exit 1
			}
			current_branch="$new_branch"
			echo "[git-upload] Successfully created and switched to '$new_branch'." >&2
		else
			# Detached HEAD with commit on multiple branches
			if [ "$use_ai" = true ]; then
				# With -ai, pick the most likely branch: prefer main/master, then
				# the branch whose tip is closest to HEAD.
				local best_branch=""
				while IFS= read -r candidate; do
					[ -z "$candidate" ] && continue
					case "$candidate" in
						main|master|develop)
							best_branch="$candidate"
							break
							;;
					esac
					[ -z "$best_branch" ] && best_branch="$candidate"
				done <<< "$containing_branches"

				if [ -n "$best_branch" ]; then
					echo "[git-upload] Detached HEAD exists on multiple branches. With -ai, picking '$best_branch'…" >&2
					printf '%s\n' "$containing_branches" | sed 's/^/  - /' >&2
					git switch "$best_branch" >/dev/null 2>&1 || {
						echo "[git-upload] Failed to switch to '$best_branch'." >&2
						exit 1
					}
					current_branch="$best_branch"
					echo "[git-upload] ✅ Switched to '$best_branch'." >&2
				else
					echo "[git-upload] You are in a detached HEAD state. The commit exists on multiple branches:" >&2
					printf '%s\n' "$containing_branches" | sed 's/^/  - /' >&2
					echo "[git-upload] Fix: checkout one of those branches (e.g., 'git switch <branch-name>') before running git-upload." >&2
					exit 1
				fi
			else
				echo "[git-upload] You are in a detached HEAD state. The commit exists on multiple branches:" >&2
				printf '%s\n' "$containing_branches" | sed 's/^/  - /' >&2
				echo "[git-upload] Fix: checkout one of those branches (e.g., 'git switch <branch-name>') before running git-upload." >&2
				echo "[git-upload] Tip: Use -ai to auto-select the most likely branch." >&2
				exit 1
			fi
		fi
	fi

	# If this branch has an upstream, first make sure we're not behind it.
	# If we are, attempt a rebase so pushes will be fast-forward and won't
	# immediately fail due to "non-fast-forward" errors.
	if upstream_ref=$(git rev-parse --abbrev-ref --symbolic-full-name "@{u}" 2>/dev/null); then
		# Make sure we have the latest refs
		git fetch >/dev/null 2>&1 || true

		ahead_behind=$(git rev-list --left-right --count "$upstream_ref"...HEAD 2>/dev/null || echo "")
		behind_count=$(printf '%s\n' "$ahead_behind" | awk '{print $1}')

		if [ -n "$behind_count" ] && [ "$behind_count" -gt 0 ]; then
			echo "[git-upload] Branch '$current_branch' is $behind_count commit(s) behind its upstream. Rebasing..." >&2
			if ! git pull --rebase --autostash >/dev/null 2>&1; then
				GIT_DIR=$(git rev-parse --git-dir 2>/dev/null || echo .git)
				if [ -d "$GIT_DIR/rebase-merge" ] || [ -d "$GIT_DIR/rebase-apply" ] || [ -f "$GIT_DIR/MERGE_HEAD" ]; then
					echo "[git-upload] git pull --rebase --autostash stopped due to conflicts." >&2
					echo "[git-upload] Run 'git resolve' for a safe backup and conflict-resolution guidance, resolve conflicts, then rerun git-upload." >&2
				else
					echo "[git-upload] git pull --rebase --autostash failed for this branch (for example, due to local changes or a hook/network error)." >&2
					echo "[git-upload] Run 'git resolve' for a safe backup and guidance on cleaning up your working tree, then rerun git-upload." >&2
				fi
				exit 1
			fi
		fi

		# After ensuring we're up to date, do a dry-run push to catch
		# permission/branch-protection issues before burning AI tokens.
		if ! git push --dry-run >/dev/null 2>&1; then
			echo "[git-upload] Unable to push to the upstream for '$current_branch'." >&2
			echo "[git-upload] This branch may be protected or you may not have permission to push directly." >&2
			echo "[git-upload] Push via a pull request or use a different branch before running git-upload." >&2
			exit 1
		fi
	fi

	# Force stage all changes (including after stash pop which may leave files unstaged)
	git add -A

	local repo_root
	repo_root=$(git rev-parse --show-toplevel 2>/dev/null || echo "")
	if ! ensure_version_bump_release_notes "$repo_root"; then
		exit 1
	fi

	# Check for sensitive files being committed and warn (but don't block)
	local sensitive_staged=""
	sensitive_staged=$(git diff --cached --name-only 2>/dev/null | grep -iE '\.(env|pem|key|p12|pfx|log)$|^\.env|id_rsa|id_dsa|id_ecdsa|id_ed25519|credentials|secrets\.(json|yml|yaml)$|\.npmrc$|\.pypirc$|\.netrc$' || true)
	if [ -n "$sensitive_staged" ]; then
		echo "" >&2
		echo "[git-upload] ⚠️  SENSITIVE FILES DETECTED IN STAGED CHANGES:" >&2
		echo "$sensitive_staged" | while read -r file; do
			echo "[git-upload]   • $file" >&2
		done
		echo "" >&2
		echo "[git-upload] 💡 If this is intentional (e.g., testing git-help-i-pushed-an-env)," >&2
		echo "[git-upload]    the AI will try to infer context from recent commits." >&2
		echo "[git-upload]    If accidental, press Ctrl+C NOW and run: git reset HEAD" >&2
		echo "" >&2
		sleep 2  # Give user a moment to cancel if needed
	fi

	# Check if there's anything to commit (staged changes)
	if git diff --cached --quiet 2>/dev/null; then
		# Double-check with git status in case add failed silently
		if ! git status --porcelain 2>/dev/null | grep -q '^'; then
			echo "[git-upload] Nothing to commit – working tree is clean." >&2
			exit 1
		fi
		# There are changes but they're not staged - force add again
		echo "[git-upload] Re-staging unstaged changes..." >&2
		git add -A
	fi

	commit_msg="${user_msg:-default commit message}"

	if [ "$use_ai" = true ]; then
		if ai_msg=$(generate_ai_message); then
			# Prefer AI message; fall back to user_msg if AI returns empty
			if [ -n "${ai_msg// /}" ]; then
				commit_msg="$ai_msg"
			fi
		else
			# AI failed (e.g., Copilot not authenticated or not available)
			if [ -z "$user_msg" ]; then
				# No manual fallback message was provided; abort commit
				echo "[git-upload] AI commit requested but unavailable and no fallback commit message provided. Aborting commit." >&2
				exit 1
			fi
		fi
	fi

	echo "[git-upload] Using commit message: $commit_msg" >&2

	git commit -m "$commit_msg"

	# Push to the current branch's upstream if configured; otherwise
	# create/set upstream on origin for the current branch.
	if git rev-parse --abbrev-ref --symbolic-full-name "@{u}" >/dev/null 2>&1; then
		git push
	else
		git push -u origin "$current_branch"
	fi
}

if [ "${GIT_UPLOAD_LIBRARY_ONLY-}" != "1" ]; then
	main "$@"
fi
