#!/bin/zsh

# git-help-i-pushed-an-env
#
# Usage:
#   git-help-i-pushed-an-env [options]
#
# Description:
#   Emergency tool to completely remove environment secrets, log files, and
#   other sensitive data from git repository history. Supports cleaning single
#   repositories or batch cleaning all public/private GitHub repositories.
#
# Options:
#   -h, --help                  Show this help message
#   -i, --interactive           Interactive mode: scan and handle each file individually
#   -n, --dry-run               Show what would be removed without making changes
#   -f, --force                 Skip confirmation prompts
#   -v, --verbose               Show detailed output
#   --scan                      Only scan for sensitive files (no removal)
#   --scan-all-public           Scan ALL public GitHub repositories
#   --scan-all-repos            Scan ALL repositories (public AND private)
#   --review                    Run git-scan-for-leaked-envs after cleaning
#   --ext EXTENSION             Add file extension to remove (can be used multiple times)
#   --file PATTERN              Add file pattern to remove (can be used multiple times)
#   --search PATTERN            Search for specific file patterns in workspace
#   --all-public                Run on ALL public GitHub repositories
#   --all-repos                 Run on ALL repositories (public AND private)
#   --preserve-recent           Only clean commits older than 24 hours
#   --backup                    Create a backup branch before cleaning
#   --no-cache                  Ignore cache and rescan all repositories

set -euo pipefail

export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:$PATH"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# ------------------------------------------------------------------
# Load library modules
# ------------------------------------------------------------------
source "${SCRIPT_DIR}/lib/env-ui.sh"
source "${SCRIPT_DIR}/lib/env-patterns.sh"
source "${SCRIPT_DIR}/lib/env-cache.sh"
source "${SCRIPT_DIR}/lib/env-git-ops.sh"
source "${SCRIPT_DIR}/lib/env-scan.sh"
source "${SCRIPT_DIR}/lib/env-history-clean.sh"
source "${SCRIPT_DIR}/lib/env-batch-ops.sh"

# ------------------------------------------------------------------
# Configuration flags (read by library functions)
# ------------------------------------------------------------------
dry_run=false
force=false
verbose=false
run_review=false
all_public=false
all_repos=false
preserve_recent=false
create_backup=false
interactive_mode=false
scan_only=false
scan_all_public=false
scan_all_repos=false
no_cache=false
extra_extensions=()
extra_files=()
search_patterns=()

trap 'stop_spinner' EXIT INT TERM

# ------------------------------------------------------------------
# Help
# ------------------------------------------------------------------
print_help() {
	printf '%s\n' "git-help-i-pushed-an-env - Emergency tool to remove secrets from git history"
	printf '\n'
	printf '%s\n' "USAGE:"
	printf '%s\n' "    git-help-i-pushed-an-env [options]"
	printf '\n'
	printf '%s\n' "DESCRIPTION:"
	printf '%s\n' "    Completely removes environment secrets, log files, and other sensitive data"
	printf '%s\n' "    from the ENTIRE git repository history. This is a destructive operation that"
	printf '%s\n' "    rewrites git history."
	printf '\n'
	printf '%s\n' "    Files that are properly listed in .gitignore and have NEVER been committed"
	printf '%s\n' "    will not be flagged as issues."
	printf '\n'
	printf '%s\n' "MODES:"
	printf '%s\n' "    Default mode:   Scan for all known sensitive patterns and remove them"
	printf '%s\n' "    Interactive:    (-i) Review each file individually with options"
	printf '%s\n' "    Scan only:      (--scan) Just show what would be found, no changes"
	printf '\n'
	printf '%s\n' "OPTIONS:"
	printf '%s\n' "    -h, --help                  Show this help message"
	printf '%s\n' "    -i, --interactive           Interactive mode: handle each file individually"
	printf '%s\n' "    -n, --dry-run               Show what would be removed without making changes"
	printf '%s\n' "    -f, --force                 Skip confirmation prompts"
	printf '%s\n' "    -v, --verbose               Show detailed output"
	printf '%s\n' "    --scan                      Only scan for sensitive files (no removal)"
	printf '%s\n' "    --scan-all-public           Scan ALL public GitHub repos (no changes)"
	printf '%s\n' "    --scan-all-repos            Scan ALL repos - public AND private (no changes)"
	printf '%s\n' "    --review                    Run git-scan-for-leaked-envs after cleaning"
	printf '%s\n' "    --ext EXTENSION             Add file extension to remove (e.g., --ext .pem)"
	printf '%s\n' "    --file PATTERN              Add file pattern to remove"
	printf '%s\n' "    --search PATTERN            Search for specific patterns"
	printf '%s\n' "    --all-public                Clean ALL your public GitHub repositories"
	printf '%s\n' "    --all-repos                 Clean ALL repositories (public AND private)"
	printf '%s\n' "    --preserve-recent           Only clean commits older than 24 hours"
	printf '%s\n' "    --backup                    Create a backup branch before cleaning"
	printf '%s\n' "    --no-cache                  Ignore cache and rescan all repositories"
	printf '\n'
	printf '%s\n' "EXAMPLES:"
	printf '%s\n' "    git-help-i-pushed-an-env -i                  Interactive mode"
	printf '%s\n' "    git-help-i-pushed-an-env --scan              Just scan, don't remove"
	printf '%s\n' "    git-help-i-pushed-an-env --scan-all-public   Scan all public repos"
	printf '%s\n' "    git-help-i-pushed-an-env --dry-run           Preview what would be removed"
	printf '%s\n' "    git-help-i-pushed-an-env --all-public        Clean all public repos"
	printf '\n'
	printf '%s\n' "SEE ALSO:"
	printf '%s\n' "    git-scan-for-leaked-envs(1) - Scan repository for leaked secrets"
}

# ------------------------------------------------------------------
# Argument parsing
# ------------------------------------------------------------------
while [[ $# -gt 0 ]]; do
	case "$1" in
		-h|--help)      print_help; exit 0 ;;
		-n|--dry-run)   dry_run=true; shift ;;
		-f|--force)     force=true; shift ;;
		-v|--verbose)   verbose=true; shift ;;
		-i|--interactive) interactive_mode=true; shift ;;
		--scan)         scan_only=true; shift ;;
		--scan-all-public) scan_all_public=true; shift ;;
		--scan-all-repos)  scan_all_repos=true; shift ;;
		--search)       search_patterns+=("$2"); shift 2 ;;
		--review)       run_review=true; shift ;;
		--ext)          extra_extensions+=("$2"); shift 2 ;;
		--file)         extra_files+=("$2"); shift 2 ;;
		--all-public)   all_public=true; shift ;;
		--all-repos)    all_repos=true; shift ;;
		--preserve-recent) preserve_recent=true; shift ;;
		--backup)       create_backup=true; shift ;;
		--no-cache)     no_cache=true; shift ;;
		*)
			log_error "Unknown option: $1"
			print_help
			exit 2
			;;
	esac
done

# ------------------------------------------------------------------
# Main dispatch
# ------------------------------------------------------------------
printf '\n%bgit-help-i-pushed-an-env%b - Remove secrets from git history\n\n' "$BOLD" "$NC"

check_dependencies

if [ "$scan_all_repos" = true ]; then
	scan_multiple_repos "all"
elif [ "$scan_all_public" = true ]; then
	scan_multiple_repos "public"
elif [ "$all_repos" = true ]; then
	clean_multiple_repos "all"
elif [ "$all_public" = true ]; then
	clean_multiple_repos "public"
elif [ "$scan_only" = true ]; then
	check_git_repo
	run_scan_only
elif [ "$interactive_mode" = true ]; then
	check_git_repo
	run_interactive_mode
else
	check_git_repo
	clean_repository
fi
