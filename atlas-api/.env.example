# Required — your OpenAI API key (never exposed to clients)
OPENAI_API_KEY=sk-...

# Required — secret for signing JWT auth tokens (generate a random 64-char string)
JWT_SECRET=change-me-to-a-random-secret

# Required — the GitHub Pages origin that may call this API
ALLOWED_ORIGIN=https://rockywearsahat.github.io

# Optional — override the default model (gpt-4o-mini)
# AI_MODEL=gpt-4o
